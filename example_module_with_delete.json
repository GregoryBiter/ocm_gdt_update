{
    "module_name": "Example Module",
    "creator_name": "gregorybiter",
    "creator_email": "gregorybiter@gmail.com",
    "code": "example_module",
    "version": "1.0.0",
    "description": "Пример модуля с поддержкой удаления файлов и директорий",
    "controller": "admin/controller/extension/module/example_module.php",
    "files": [
        "admin/controller/extension/module/example_module.php",
        "admin/language/en-gb/extension/module/example_module.php",
        "admin/language/ru-ru/extension/module/example_module.php",
        "admin/language/uk-ua/extension/module/example_module.php",
        "admin/view/template/extension/module/example_module.twig",
        "catalog/controller/extension/module/example_module.php",
        "catalog/model/extension/module/example_module.php"
    ],
    "delete": [
        "system/temp/example_module_cache/",
        "system/logs/example_module.log",
        "admin/view/javascript/example_module/",
        {
            "path": "image/example_module/",
            "type": "directory",
            "description": "Удаляет директорию с изображениями модуля"
        },
        {
            "path": "system/storage/cache/example_module.cache",
            "type": "file",
            "description": "Удаляет файл кэша модуля"
        }
    ]
}
