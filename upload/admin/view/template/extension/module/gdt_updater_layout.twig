    font-size: 14px;
    margin: 0;
}

/* Стили для страницы установки модулей */
.install-modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 20px;
    margin-top: 15px;
}

.install-module-card {
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 20px;
    background: #fff;
    transition: all 0.2s ease;
    position: relative;
}

.install-module-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transform: translateY(-2px);
}

.install-module-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
}

.install-module-title {
    font-size: 16px;
    font-weight: 600;
    color: #333;
    margin: 0;
    flex: 1;
}

.install-module-version {
    background: #e9ecef;
    color: #495057;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
    margin-left: 10px;
}

.install-module-description {
    color: #666;
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 15px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.install-module-meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 15px;
    font-size: 13px;
    color: #666;
}

.install-module-meta-item {
    display: flex;
    justify-content: space-between;
}

.install-module-meta-label {
    font-weight: 600;
    color: #333;
}

.install-module-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.install-module-btn {
    background: #28a745;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.install-module-btn:hover {
    background: #218838;
    text-decoration: none;
    color: white;
}

.install-module-btn:disabled {
    background: #6c757d;
    cursor: not-allowed;
}

.install-module-btn i {
    font-size: 12px;
}

.install-module-link {
    color: #007cba;
    text-decoration: none;
    font-size: 13px;
}

.install-module-link:hover {
    text-decoration: underline;
}

.install-module-installed {
    background: #d4edda;
    color: #155724;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
}

.install-modules-search {
    margin-bottom: 20px;
}

.install-modules-search input {
    width: 100%;
    padding: 10px 15px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 14px;
}

.install-modules-filter {
    display: flex;
    gap: 10px;
    margin-bottom: 15px;
    flex-wrap: wrap;
}

.filter-btn {
    padding: 6px 12px;
    border: 1px solid #ddd;
    background: #fff;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    transition: all 0.2s ease;
