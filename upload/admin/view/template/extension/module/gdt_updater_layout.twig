}

.module-item:hover {
    background-color: #f8f9fa;
}

.module-item.has-update {
    border-left: 4px solid #dc3545;
}

.module-item.up-to-date {
    border-left: 4px solid #28a745;
}

.module-column-1 {
    display: flex;
    flex-direction: column;
}

.module-title {
    font-size: 15px;
    font-weight: 600;
    margin: 0 0 5px 0;
    color: #333;
    display: flex;
    align-items: center;
}

.module-title i {
    margin-right: 8px;
    color: #007cba;
    font-size: 16px;
}

.module-actions-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
}

.action-link {
    color: #007cba;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    padding: 2px 0;
    border-bottom: 1px solid transparent;
    transition: all 0.2s ease;
}

.action-link:hover {
    color: #005a87;
    border-bottom-color: #005a87;
    text-decoration: none;
}

.action-link.update-link {
    color: #dc3545;
    font-weight: 600;
}

.action-link.update-link:hover {
    color: #b02a37;
    border-bottom-color: #b02a37;
}

.action-link.delete-link {
    color: #dc3545;
    font-weight: 500;
}

.action-link.delete-link:hover {
    color: #a71e2a;
    border-bottom-color: #a71e2a;
    background-color: #f8d7da;
    padding: 2px 4px;
    border-radius: 3px;
}

.action-separator {
    color: #ccc;
    margin: 0 2px;
}

.module-column-2 {
    display: flex;
    flex-direction: column;
    gap: 2px;
}

.module-description {
    color: #666;
    font-size: 14px;
    line-height: 1.5;
    margin: 0 0 0px 0;
}

.module-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 13px;
    color: #666;
}

.meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
}

.meta-label {
    font-weight: 600;
    color: #333;
}

.version-current {
    color: #666;
    background: #f1f3f4;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 12px;
}

.version-new {
    color: #d63384;
    background: #fdf2f8;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
}

.module-author {
    color: #007cba;
    text-decoration: none;
}

.module-author:hover {
    text-decoration: underline;
}

.module-column-3 {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.auto-update-section {
    width: 100%;
}

.auto-update-label {
    font-size: 13px;
    font-weight: 600;
    color: #333;
    margin-bottom: 8px;
    display: block;
}

.auto-update-link {
    color: #007cba;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
