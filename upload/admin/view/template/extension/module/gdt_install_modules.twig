{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" id="button-refresh" data-loading-text="Загрузка..." class="btn btn-info"><i class="fa fa-refresh"></i> Обновить список</button>
        <a href="{{ back }}" data-toggle="tooltip" title="Назад" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ page_title|default('Установка модулей') }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <!-- Сообщения -->
    <div id="alert-container"></div>
    
    <!-- Навигация между страницами -->
    <div class="panel panel-default">
      <div class="panel-body">
        <div class="btn-group" role="group">
          <a href="{{ store_url }}" class="btn btn-default {% if current_page == 'store' %}active{% endif %}">
            <i class="fa fa-shopping-cart"></i> Магазин модулей
          </a>
          <a href="{{ featured_url }}" class="btn btn-default {% if current_page == 'featured' %}active{% endif %}">
            <i class="fa fa-star"></i> Рекомендуемые
          </a>
          <a href="{{ popular_url }}" class="btn btn-default {% if current_page == 'popular' %}active{% endif %}">
            <i class="fa fa-trophy"></i> Популярные
          </a>
          <a href="{{ newest_url }}" class="btn btn-default {% if current_page == 'newest' %}active{% endif %}">
            <i class="fa fa-clock-o"></i> Новые
          </a>
          <a href="{{ search_url }}" class="btn btn-default {% if current_page == 'search' %}active{% endif %}">
            <i class="fa fa-search"></i> Поиск
          </a>
        </div>
      </div>
    </div>

    <!-- Контент страницы -->
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title">
          {% if current_page == 'store' %}
            <i class="fa fa-shopping-cart"></i> {{ page_title|default('Магазин модулей') }}
          {% elseif current_page == 'featured' %}
            <i class="fa fa-star"></i> {{ page_title|default('Рекомендуемые модули') }}
          {% elseif current_page == 'popular' %}
            <i class="fa fa-trophy"></i> {{ page_title|default('Популярные модули') }}
          {% elseif current_page == 'newest' %}
            <i class="fa fa-clock-o"></i> {{ page_title|default('Новые модули') }}
          {% elseif current_page == 'search' %}
            <i class="fa fa-search"></i> {{ page_title|default('Поиск модулей') }}
          {% else %}
            <i class="fa fa-puzzle-piece"></i> {{ page_title|default('Установка модулей') }}
          {% endif %}
        </h3>
      </div>
      <div class="panel-body">
        {% if page_description %}
        <p class="text-muted">{{ page_description }}</p>
        {% endif %}
        
        {% if current_page == 'search' or current_page == 'store' %}
        <!-- Форма поиска -->
        <div class="search-form">
          <div class="row">
            <div class="col-md-8">
              <input type="text" id="search-input" class="form-control" placeholder="Введите название модуля или ключевые слова...">
            </div>
            <div class="col-md-4">
              <button type="button" id="search-button" class="btn btn-primary btn-block">
                <i class="fa fa-search"></i> {{ current_page == 'store' ? 'Поиск в магазине' : 'Найти модули' }}
              </button>
            </div>
          </div>
          <div class="row" style="margin-top: 15px;">
            <div class="col-md-4">
              <select id="search-category" class="form-control">
                <option value="">Все категории</option>
                <option value="ecommerce">Электронная коммерция</option>
                <option value="shipping">Доставка</option>
                <option value="payment">Платежи</option>
                <option value="seo">SEO</option>
                <option value="analytics">Аналитика</option>
                <option value="marketing">Маркетинг</option>
                <option value="design">Дизайн</option>
                <option value="tools">Инструменты</option>
              </select>
            </div>
            <div class="col-md-4">
              <select id="search-sort" class="form-control">
                <option value="relevance">По релевантности</option>
                <option value="popularity">По популярности</option>
                <option value="rating">По рейтингу</option>
                <option value="date">По дате</option>
                <option value="name">По названию</option>
              </select>
            </div>
            <div class="col-md-4">
              <select id="search-price" class="form-control">
                <option value="">Любая цена</option>
                <option value="free">Бесплатные</option>
                <option value="paid">Платные</option>
              </select>
            </div>
          </div>
        </div>
        {% endif %}
        
        <!-- Контейнер для модулей -->
        <div id="modules-container">
          {% if current_page != 'search' %}
          <div class="text-center loading-content">
            <i class="fa fa-spinner fa-spin fa-2x"></i>
            <p>Загрузка {{ page_title|lower }}...</p>
          </div>
          {% else %}
          <div class="text-center">
            <i class="fa fa-search fa-2x"></i>
            <p>Введите поисковый запрос для поиска модулей</p>
          </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
/* WordPress-styled App Store CSS */
.pw-panel { border: none; box-shadow: 0 1px 1px rgba(0,0,0,.04); border-radius: 4px; }
.pw-panel-heading { background: #fff !important; padding: 15px 20px; border-bottom: 1px solid #ccd0d4; }
.pw-panel-heading .panel-title { font-size: 18px; font-weight: 400; color: #1d2327; }

/* Filter Navigation */
.nav-tabs { border-bottom: 1px solid #ccd0d4; margin-bottom: 20px; padding-left: 10px; }
.nav-tabs > li > a { border: none; color: #2271b1; padding: 10px 15px; font-size: 14px; font-weight: 400; background: transparent !important; }
.nav-tabs > li > a:hover { color: #135e96; }
.nav-tabs > li.active > a, .nav-tabs > li.active > a:hover, .nav-tabs > li.active > a:focus {
    color: #1d2327;
    font-weight: 600;
    border-bottom: 3px solid #2271b1;
}

/* Modules Grid */
.modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 20px;
}

.module-card {
    background: #fff;
    border: 1px solid #c3c4c7;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.module-card.featured { border-left: 4px solid #b32d2e; }

/* Top Section: Icon, Title, Author, Description */
.pw-plugin-card-top {
    padding: 20px;
    border-bottom: 1px solid #f0f0f1;
    min-height: 180px;
}

.pw-plugin-card-title {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
}
.pw-plugin-card-title h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: #1d2327;
}

.pw-plugin-card-desc {
    color: #3c434a;
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: 15px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Bottom Section: Installs, Rating, Install Button */
.pw-plugin-card-bottom {
    background: #f6f7f7;
    padding: 15px 20px;
    border-top: 1px solid #f0f0f1;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.pw-plugin-action { flex: 1; }
.install-btn {
    background: #f6f7f7;
    border: 1px solid #2271b1;
    color: #2271b1;
    padding: 4px 12px;
    border-radius: 3px;
    font-size: 13px;
    text-decoration: none;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
}
.install-btn:hover { background: #f0f0f1; color: #135e96; border-color: #135e96; }
.install-btn.installed { background: #f6f7f7; color: #2c3338; border-color: #8c8f94; cursor: default; }

.module-meta-info {
    font-size: 12px;
    color: #8c8f94;
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.search-form { padding: 20px 0; }
.loading-content { text-align: center; padding: 60px; color: #8c8f94; }

.no-modules { text-align: center; padding: 60px 20px; color: #8c8f94; }
.no-modules i { font-size: 48px; color: #dcdcde; margin-bottom: 15px; }
.no-modules h3 { font-size: 18px; color: #3c434a; margin-bottom: 10px; }

@media (max-width: 768px) {
    .modules-grid { grid-template-columns: 1fr; }
}
</style>

<script type="text/javascript"><!--
// URL-адреса для AJAX запросов
var ajaxUrls = {
    getFeaturedModules: '{{ get_modules_url|default("") }}',
    getPopularModules: '{{ get_modules_url|default("") }}',
    getNewestModules: '{{ get_modules_url|default("") }}',
    getStoreModules: '{{ get_modules_url|default("") }}',
    searchModules: '{{ search_modules_url|default("") }}',
    installModule: '{{ install_module_url|default("") }}'
};

var currentPage = '{{ current_page|default("") }}';
var userToken = '{{ user_token }}';

// Функция для отображения уведомлений
function showAlert(type, message) {
    var alertClass = 'alert-' + type;
    var iconClass = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    
    var alert = '<div class="alert ' + alertClass + ' alert-dismissible">';
    alert += '<i class="fa ' + iconClass + '"></i> ' + message;
    alert += '<button type="button" class="close" data-dismiss="alert">&times;</button>';
    alert += '</div>';
    
    $('#alert-container').html(alert);
    
    // Автоматически скрыть через 5 секунд
    setTimeout(function() {
        $('#alert-container .alert').alert('close');
    }, 5000);
}

// Загрузка модулей для текущей страницы
function loadModules() {
    var url = '';
    
    switch(currentPage) {
        case 'store':
            url = ajaxUrls.getStoreModules;
            break;
        case 'featured':
            url = ajaxUrls.getFeaturedModules;
            break;
        case 'popular':
            url = ajaxUrls.getPopularModules;
            break;
        case 'newest':
            url = ajaxUrls.getNewestModules;
            break;
        default:
            return;
    }
    
    if (!url) {
        $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка</h3><p>URL для загрузки модулей не найден</p></div>');
        return;
    }
    
    $.ajax({
        url: url,
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка загрузки</h3><p>' + json.error + '</p></div>');
            } else if (json.modules) {
                renderModules(json.modules, currentPage);
            } else {
                $('#modules-container').html('<div class="no-modules"><i class="fa fa-puzzle-piece"></i><h3>Модули не найдены</h3><p>Нет доступных модулей в данной категории</p></div>');
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            console.log('AJAX Error:', xhr.status, thrownError);
            $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка подключения</h3><p>Не удалось загрузить список модулей с сервера. Код ошибки: ' + xhr.status + '</p></div>');
        }
    });
}

// Поиск модулей
function searchModules() {
    var query = $('#search-input').val();
    var category = $('#search-category').val();
    var sort = $('#search-sort').val();
    var price = $('#search-price').val();
    
    if (!query.trim()) {
        showAlert('warning', 'Введите поисковый запрос');
        return;
    }
    
    $('#modules-container').html('<div class="text-center loading-content"><i class="fa fa-spinner fa-spin fa-2x"></i><p>Поиск модулей...</p></div>');
    
    // Определяем URL для поиска в зависимости от текущей страницы
    var searchUrl;
    if (currentPage === 'store') {
        // Для страницы "Магазин модулей" используем поиск во внешнем API
        searchUrl = ajaxUrls.searchModules.replace('/searchModules', '/searchStoreModules');
    } else {
        // Для других страниц используем обычный поиск
        searchUrl = ajaxUrls.searchModules;
    }
    
    $.ajax({
        url: searchUrl,
        type: 'POST',
        data: {
            query: query,
            category: category,
            sort: sort,
            price: price,
            user_token: userToken
        },
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка поиска</h3><p>' + json.error + '</p></div>');
            } else if (json.modules) {
                renderModules(json.modules, 'search');
            } else {
                $('#modules-container').html('<div class="no-modules"><i class="fa fa-puzzle-piece"></i><h3>Модули не найдены</h3><p>По вашему запросу ничего не найдено</p></div>');
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка поиска</h3><p>Не удалось выполнить поиск модулей</p></div>');
        }
    });
}

// Отображение модулей
function renderModules(modules, category) {
    var html = '';
    
    if (modules.length === 0) {
        html = '<div class="no-modules"><i class="fa fa-puzzle-piece"></i><h3>Модули не найдены</h3><p>Нет доступных модулей в данной категории</p></div>';
    } else {
        html += '<div class="modules-grid">';
        
        modules.forEach(function(module) {
            var cardClass = 'module-card';
            var moduleInfo = {
                code: module.code || '',
                name: module.name || '',
                module_name: module.name || '',
                version: module.version || '',
                author: module.author || '',
                description: module.description || '',
                category: module.category || 'module'
            };
            var moduleInfoPayload = encodeURIComponent(JSON.stringify(moduleInfo));

            if (category === 'featured' || module.featured) {
                cardClass += ' featured';
            }
            
            html += '<div class="' + cardClass + '">';
            
            html += '<div class="pw-plugin-card-top">';
            html += '<div class="pw-plugin-card-title">';
            html += '<h3>' + (module.name || 'Неизвестный модуль') + ' <span style="font-weight: normal; font-size: 12px; color: #8c8f94;">v' + (module.version || '1.0') + '</span></h3>';
            html += '</div>';
            html += '<div class="pw-plugin-card-desc">';
            html += '<p>' + (module.description || 'Описание отсутствует') + '</p>';
            html += '</div>';
            if (module.author) {
                html += '<p style="font-size: 13px; color: #3c434a;">Автор: ' + module.author + '</p>';
            }
            html += '</div>';
            
            html += '<div class="pw-plugin-card-bottom">';
            html += '<div class="pw-plugin-action">';
            
            if (module.installed) {
                if (module.update_available) {
                    html += '<button class="install-btn update-available" data-code="' + (module.code || '') + '" data-url="' + (module.download_url || '') + '" data-version="' + (module.version || '') + '" data-module-info="' + moduleInfoPayload + '" style="border-color: #d63638; color: #d63638;">';
                    html += 'Обновить до v' + (module.version || '');
                    html += '</button>';
                } else {
                    html += '<button class="install-btn installed" disabled>Установлен</button>';
                }
            } else {
                html += '<button class="install-btn" data-code="' + (module.code || '') + '" data-url="' + (module.download_url || '') + '" data-version="' + (module.version || '') + '" data-module-info="' + moduleInfoPayload + '">';
                html += 'Установить';
                html += '</button>';
            }
            html += '</div>';

            html += '<div class="module-meta-info">';
            if (module.rating) {
                html += '<span>★ ' + module.rating + '</span>';
            }
            if (module.downloads) {
                html += '<span>' + module.downloads + '+ скачиваний</span>';
            }
            html += '</div>';
            html += '</div>';
            html += '</div>';
        });
        
        html += '</div>';
    }
    
    $('#modules-container').html(html);
}

// Установка/обновление модуля
function installModule(moduleCode, downloadUrl, moduleVersion, serverModuleInfo, buttonElement, isUpdate) {
    if (!moduleCode || !downloadUrl) {
        showAlert('danger', 'Недостаточно данных для установки модуля');
        return;
    }
    
    var originalText = $(buttonElement).html();
    var actionText = isUpdate ? 'Обновление' : 'Установка';
    var actionTextLower = isUpdate ? 'обновления' : 'установки';
    
    $.ajax({
        url: ajaxUrls.installModule,
        type: 'POST',
        data: {
            module_code: moduleCode,
            version: moduleVersion || '',
            server_module_info: JSON.stringify(serverModuleInfo || {}),
            download_url: downloadUrl,
            user_token: userToken
        },
        dataType: 'json',
        beforeSend: function() {
            $(buttonElement).prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> ' + actionText + '...');
        },
        success: function(json) {
            if (json.success) {
                showAlert('success', json.success);
                $(buttonElement).removeClass('update-available').addClass('installed').html('<i class="fa fa-check"></i> Установлен');
            } else if (json.error) {
                showAlert('danger', json.error);
                $(buttonElement).prop('disabled', false).html(originalText);
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            showAlert('danger', 'Ошибка ' + actionTextLower + ' модуля: ' + thrownError);
            $(buttonElement).prop('disabled', false).html(originalText);
        }
    });
}

// Обработчики событий
$(document).ready(function() {
    // Автоматически загружаем модули для текущей страницы (кроме поиска)
    if (currentPage && currentPage !== 'search') {
        loadModules();
    }
    
    // Кнопка обновления списка
    $('#button-refresh').on('click', function() {
        var button = $(this);
        button.button('loading');
        
        if (currentPage === 'search') {
            // Для поиска повторяем последний поиск
            searchModules();
        } else {
            loadModules();
        }
        
        setTimeout(function() {
            button.button('reset');
        }, 1000);
    });
    
    // Поиск модулей
    $('#search-button').on('click', function() {
        searchModules();
    });
    
    $('#search-input').on('keypress', function(e) {
        if (e.which === 13) {
            searchModules();
        }
    });
    
    // Установка/обновление модуля
    $(document).on('click', '.install-btn:not(.installed)', function(e) {
        e.preventDefault();
        var moduleCode = $(this).data('code');
        var downloadUrl = $(this).data('url');
        var moduleVersion = $(this).data('version');
        var moduleInfoPayload = $(this).attr('data-module-info') || '';
        var serverModuleInfo = {};
        if (moduleInfoPayload) {
            try {
                serverModuleInfo = JSON.parse(decodeURIComponent(moduleInfoPayload));
            } catch (e) {
                serverModuleInfo = {};
            }
        }
        var isUpdate = $(this).hasClass('update-available');
        installModule(moduleCode, downloadUrl, moduleVersion, serverModuleInfo, this, isUpdate);
    });
});
//--></script>
{{ footer }}
