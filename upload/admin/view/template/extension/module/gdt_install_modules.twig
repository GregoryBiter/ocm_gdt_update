{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        {% if current_page == 'installed' %}
        <button type="button" id="button-delete-selected" class="btn btn-danger" disabled><i class="fa fa-trash"></i> Удалить выбранные</button>
        <button type="button" id="button-settings" class="btn btn-default"><i class="fa fa-cog"></i> Настройки</button>
        <button type="button" id="button-check" class="btn btn-primary"><i class="fa fa-refresh"></i> Проверить обновления</button>
        {% else %}
        <button type="button" id="button-refresh" data-loading-text="Загрузка..." class="btn btn-default"><i class="fa fa-refresh"></i> Обновить список</button>
        {% endif %}
        <a href="{{ back }}" data-toggle="tooltip" title="Назад" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ page_title|default('Модули') }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <!-- Сообщения -->
    <div id="alert-container"></div>

    {% if current_page == 'installed' %}
    <!-- Модальное окно настроек -->
    <div class="modal fade" id="modal-settings" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span></button>
            <h4 class="modal-title">Настройки модуля</h4>
          </div>
          <div class="modal-body">
            <form id="form-settings">
              <div class="form-group">
                <label>URL сервера обновлений</label>
                <input type="text" name="module_gdt_updater_server" id="input-server" class="form-control" />
              </div>
              <div class="form-group">
                <label>API-ключ</label>
                <input type="text" name="module_gdt_updater_api_key" id="input-api-key" class="form-control" />
              </div>
              <div class="form-group">
                <label>Статус</label>
                <select name="module_gdt_updater_status" id="input-status" class="form-control">
                  <option value="1">Включён</option>
                  <option value="0">Отключён</option>
                </select>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Отмена</button>
            <button type="button" class="btn btn-primary" id="button-save-settings">Сохранить</button>
          </div>
        </div>
      </div>
    </div>
    <!-- Модальное окно подтверждения удаления -->
    <div class="modal fade" id="modal-delete-confirm" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span></button>
            <h4 class="modal-title"><i class="fa fa-warning text-danger"></i> Подтверждение удаления</h4>
          </div>
          <div class="modal-body">
            <div class="alert alert-warning"><i class="fa fa-exclamation-triangle"></i> <strong>Внимание!</strong> Удаление модуля необратимо.</div>
            <p id="delete-message"></p>
            <div id="modules-to-delete" style="display:none;">
              <strong>Модули для удаления:</strong>
              <ul id="delete-modules-list"></ul>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Отмена</button>
            <button type="button" class="btn btn-danger" id="button-confirm-delete"><i class="fa fa-trash"></i> Удалить</button>
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    <!-- Навигация между страницами -->
    <div class="panel panel-default" style="margin-bottom:15px;">
      <div class="panel-body" style="padding:0 15px;">
        <ul class="nav nav-tabs gdt-nav-tabs">
          <li class="{% if current_page == 'installed' %}active{% endif %}">
            <a href="{{ installed_url }}"><i class="fa fa-plug"></i> Установленные</a>
          </li>
          <li class="{% if current_page == 'store' %}active{% endif %}">
            <a href="{{ store_url }}"><i class="fa fa-shopping-cart"></i> Магазин</a>
          </li>
          <li class="{% if current_page == 'featured' %}active{% endif %}">
            <a href="{{ featured_url }}"><i class="fa fa-star"></i> Рекомендуемые</a>
          </li>
          <li class="{% if current_page == 'popular' %}active{% endif %}">
            <a href="{{ popular_url }}"><i class="fa fa-trophy"></i> Популярные</a>
          </li>
          <li class="{% if current_page == 'newest' %}active{% endif %}">
            <a href="{{ newest_url }}"><i class="fa fa-clock-o"></i> Новые</a>
          </li>
          <li class="{% if current_page == 'search' %}active{% endif %}">
            <a href="{{ search_url }}"><i class="fa fa-search"></i> Поиск</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Контент страницы -->
    <div class="panel panel-default pw-panel">
      <div class="panel-heading pw-panel-heading">
        <h3 class="panel-title">
          {% if current_page == 'installed' %}
            <i class="fa fa-plug"></i> {{ page_title|default('Установленные модули') }}
          {% elseif current_page == 'store' %}
            <i class="fa fa-shopping-cart"></i> {{ page_title|default('Магазин модулей') }}
          {% elseif current_page == 'featured' %}
            <i class="fa fa-star"></i> {{ page_title|default('Рекомендуемые') }}
          {% elseif current_page == 'popular' %}
            <i class="fa fa-trophy"></i> {{ page_title|default('Популярные') }}
          {% elseif current_page == 'newest' %}
            <i class="fa fa-clock-o"></i> {{ page_title|default('Новые') }}
          {% elseif current_page == 'search' %}
            <i class="fa fa-search"></i> {{ page_title|default('Поиск') }}
          {% else %}
            <i class="fa fa-puzzle-piece"></i> {{ page_title|default('Установка модулей') }}
          {% endif %}
        </h3>
        {% if current_page == 'installed' %}
        <div class="pw-search">
          <input type="text" class="form-control" id="pw-filter-modules" placeholder="Поиск...">
        </div>
        {% endif %}
      </div>
      <div class="panel-body">
        {% if current_page == 'installed' %}
          {% if modules is empty %}
            <div class="pw-no-modules">
              <i class="fa fa-inbox"></i>
              <h3>Нет установленных модулей</h3>
              <p>Перейдите в каталог, чтобы найти и установить новые модули.</p>
              <a href="{{ store_url }}" class="btn btn-primary" style="margin-top:15px;">Посмотреть каталог</a>
            </div>
          {% else %}
            <table class="table pw-modules-table">
              <thead>
                <tr>
                  <th class="col-cb"><input type="checkbox" id="select-all-modules"></th>
                  <th class="col-name">Модуль</th>
                  <th class="col-desc">Описание</th>
                  <th class="col-auto">Автообновление</th>
                </tr>
              </thead>
              <tbody id="modules-tbody">
                {% for module in modules %}
                <tr class="pw-module-row {{ module.has_update ? 'has-update' : '' }}" data-code="{{ module.code }}">
                  <td class="col-cb">
                    <input type="checkbox" class="module-checkbox" data-code="{{ module.code }}">
                  </td>
                  <td class="col-name">
                    <h3 class="pw-module-title">{{ module.name }}</h3>
                    <div class="pw-row-actions">
                      {% if module.settings_url %}<span><a href="{{ module.settings_url }}">Настройки</a> | </span>{% endif %}
                      {% if module.has_update %}<span><a href="#" class="update-module" data-url="{{ module.update_url }}" data-code="{{ module.code }}" style="color:#d63638">Обновить</a> | </span>{% endif %}
                      {% if module.delete_url %}<span><a href="#" class="delete-module" data-url="{{ module.delete_url }}" data-code="{{ module.code }}" data-name="{{ module.name }}" style="color:#b32d2e">Удалить</a></span>{% endif %}
                    </div>
                  </td>
                  <td class="col-desc">
                    <div class="pw-module-description"><p>{{ module.description }}</p></div>
                    <div class="pw-module-meta">
                      <span>Версия {{ module.version }}</span>
                      {% if module.author %} | <span>Автор: {% if module.author_url %}<a href="{{ module.author_url }}" target="_blank">{{ module.author }}</a>{% else %}{{ module.author }}{% endif %}</span>{% endif %}
                      {% if module.has_update %}
                        <div class="pw-update-notice">
                          <strong>Доступна новая версия: {{ module.new_version }}</strong>. <a href="#" class="update-module" data-url="{{ module.update_url }}" data-code="{{ module.code }}">Обновить сейчас</a>
                        </div>
                      {% endif %}
                    </div>
                  </td>
                  <td class="col-auto">
                    <a href="#" class="auto-update-link" data-code="{{ module.code }}" data-current="{{ module.auto_update ? '1' : '0' }}">
                      {% if module.auto_update %}
                        <span style="color:#0071a1"><i class="fa fa-toggle-on"></i> Включено</span>
                      {% else %}
                        <span style="color:#2271b1"><i class="fa fa-toggle-off"></i> Включить</span>
                      {% endif %}
                    </a>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          {% endif %}
          <div id="update-results"></div>
        {% else %}
          {% if page_description %}
          <p class="text-muted">{{ page_description }}</p>
          {% endif %}

          {% if current_page == 'search' or current_page == 'store' %}
          <div class="search-form">
            <div class="row">
              <div class="col-md-8">
                <input type="text" id="search-input" class="form-control" placeholder="Введите название модуля или ключевые слова...">
              </div>
              <div class="col-md-4">
                <button type="button" id="search-button" class="btn btn-primary btn-block">
                  <i class="fa fa-search"></i> {{ current_page == 'store' ? 'Поиск в магазине' : 'Найти модули' }}
                </button>
              </div>
            </div>
            <div class="row" style="margin-top: 15px;">
              <div class="col-md-4">
                <select id="search-category" class="form-control">
                  <option value="">Все категории</option>
                  <option value="ecommerce">Электронная коммерция</option>
                  <option value="shipping">Доставка</option>
                  <option value="payment">Платежи</option>
                  <option value="seo">SEO</option>
                  <option value="analytics">Аналитика</option>
                  <option value="marketing">Маркетинг</option>
                  <option value="design">Дизайн</option>
                  <option value="tools">Инструменты</option>
                </select>
              </div>
              <div class="col-md-4">
                <select id="search-sort" class="form-control">
                  <option value="relevance">По релевантности</option>
                  <option value="popularity">По популярности</option>
                  <option value="rating">По рейтингу</option>
                  <option value="date">По дате</option>
                  <option value="name">По названию</option>
                </select>
              </div>
              <div class="col-md-4">
                <select id="search-price" class="form-control">
                  <option value="">Любая цена</option>
                  <option value="free">Бесплатные</option>
                  <option value="paid">Платные</option>
                </select>
              </div>
            </div>
          </div>
          {% endif %}

          <div id="modules-container">
            {% if current_page != 'search' %}
            <div class="text-center loading-content">
              <i class="fa fa-spinner fa-spin fa-2x"></i>
              <p>Загрузка {{ page_title|lower }}...</p>
            </div>
            {% else %}
            <div class="text-center">
              <i class="fa fa-search fa-2x"></i>
              <p>Введите поисковый запрос для поиска модулей</p>
            </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
/* WordPress-styled App Store CSS */
.pw-panel { border: none; box-shadow: 0 1px 1px rgba(0,0,0,.04); border-radius: 4px; }
.pw-panel-heading { background: #fff !important; padding: 15px 20px; border-bottom: 1px solid #ccd0d4; }
.pw-panel-heading .panel-title { font-size: 18px; font-weight: 400; color: #1d2327; }

/* Filter Navigation */
.gdt-nav-tabs { border-bottom: 1px solid #ccd0d4; margin-bottom: 0; padding-left: 0; }
.gdt-nav-tabs > li > a { border: none !important; color: #2271b1; padding: 10px 15px; font-size: 14px; font-weight: 400; background: transparent !important; }
.gdt-nav-tabs > li > a:hover { color: #135e96; background: #f8f9fa !important; }
.gdt-nav-tabs > li.active > a, .gdt-nav-tabs > li.active > a:hover, .gdt-nav-tabs > li.active > a:focus {
    color: #1d2327;
    font-weight: 600;
    border-bottom: 3px solid #2271b1 !important;
    background: #fff !important;
}

/* Installed Modules Table */
.pw-panel-heading { display: flex; justify-content: space-between; align-items: center; }
.pw-search { max-width: 250px; }
.pw-search input { height: 32px; font-size: 13px; border: 1px solid #8c8f94; border-radius: 4px; }
.pw-modules-table { margin-bottom: 0; }
.pw-modules-table thead th { border-bottom: 1px solid #ccd0d4 !important; color: #2c3338; font-size: 14px; font-weight: 400; padding: 8px 10px; }
.pw-modules-table tbody tr { border-top: 1px solid #c3c4c7; }
.pw-modules-table tbody tr:last-child { border-bottom: 1px solid #c3c4c7; }
.pw-modules-table tbody tr.has-update { background-color: #fcf0f1; }
.pw-modules-table tbody td { padding: 15px 10px; vertical-align: top; border-top: none !important; }
.col-cb { width: 40px; text-align: center; }
.col-name { width: 22%; }
.col-desc { width: 58%; }
.col-auto { width: 15%; }
.pw-module-title { font-size: 14px; font-weight: 600; margin: 0 0 4px; color: #2271b1; }
.pw-row-actions { visibility: hidden; font-size: 13px; padding: 2px 0 0; }
.pw-module-row:hover .pw-row-actions { visibility: visible; }
.pw-row-actions a { color: #2271b1; text-decoration: none; }
.pw-row-actions a:hover { text-decoration: underline; }
.pw-module-description p { margin: 0 0 6px; font-size: 13px; line-height: 1.5; color: #3c434a; }
.pw-module-meta { font-size: 12px; color: #a7aaad; }
.pw-module-meta a { color: #3c434a; text-decoration: none; }
.pw-module-meta a:hover { color: #2271b1; }
.pw-update-notice { background: #fcf0f1; border-left: 4px solid #d63638; padding: 8px 12px; margin-top: 8px; font-size: 13px; color: #1d2327; }
.pw-update-notice a { color: #d63638; }
.pw-no-modules { text-align: center; padding: 60px 20px; }
.pw-no-modules i { font-size: 48px; color: #c3c4c7; margin-bottom: 15px; display: block; }
.auto-update-link { display: inline-block; padding: 4px 0; text-decoration: none; font-size: 13px; }
.auto-update-link:hover { text-decoration: underline; }

/* Modules Grid */
.modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 20px;
}

.module-card {
    background: #fff;
    border: 1px solid #c3c4c7;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.module-card.featured { border-left: 4px solid #b32d2e; }

/* Top Section: Icon, Title, Author, Description */
.pw-plugin-card-top {
    padding: 20px;
    border-bottom: 1px solid #f0f0f1;
    min-height: 180px;
}

.pw-plugin-card-title {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
}
.pw-plugin-card-title h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: #1d2327;
}

.pw-plugin-card-desc {
    color: #3c434a;
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: 15px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Bottom Section: Installs, Rating, Install Button */
.pw-plugin-card-bottom {
    background: #f6f7f7;
    padding: 15px 20px;
    border-top: 1px solid #f0f0f1;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.pw-plugin-action { flex: 1; }
.install-btn {
    background: #f6f7f7;
    border: 1px solid #2271b1;
    color: #2271b1;
    padding: 4px 12px;
    border-radius: 3px;
    font-size: 13px;
    text-decoration: none;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
}
.install-btn:hover { background: #f0f0f1; color: #135e96; border-color: #135e96; }
.install-btn.installed { background: #f6f7f7; color: #2c3338; border-color: #8c8f94; cursor: default; }
.install-btn.update-available { background: #fff3cd; border-color: #e0a800; color: #856404; }
.install-btn.update-available:hover { background: #ffe69c; }

.module-meta-info {
    font-size: 12px;
    color: #8c8f94;
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.search-form { padding: 20px 0; }
.loading-content { text-align: center; padding: 60px; color: #8c8f94; }

.no-modules { text-align: center; padding: 60px 20px; color: #8c8f94; }
.no-modules i { font-size: 48px; color: #dcdcde; margin-bottom: 15px; }
.no-modules h3 { font-size: 18px; color: #3c434a; margin-bottom: 10px; }

@media (max-width: 768px) {
    .modules-grid { grid-template-columns: 1fr; }
    .pw-modules-table thead { display: none; }
    .pw-modules-table tbody td { display: block; width: 100% !important; border: none !important; padding: 8px 10px; }
    .pw-row-actions { visibility: visible; }
    .col-cb, .col-auto { width: auto; }
}
</style>

<script type="text/javascript"><!--
// URL-адреса для AJAX запросов
var ajaxUrls = {
    getFeaturedModules:   '{{ get_modules_url|default("") }}',
    getPopularModules:    '{{ get_modules_url|default("") }}',
    getNewestModules:     '{{ get_modules_url|default("") }}',
    getStoreModules:      '{{ get_modules_url|default("") }}',
    searchModules:        '{{ search_modules_url|default("") }}',
    installModule:        '{{ install_module_url|default("") }}',
    settings:             '{{ settings_url|default("") }}',
    saveSettings:         '{{ save_settings_url|default("") }}',
    checkUpdates:         '{{ check_updates_url|default("") }}',
    toggleAutoUpdate:     '{{ toggle_auto_update_url|default("") }}',
    deleteMultiple:       '{{ delete_multiple_url|default("") }}'
};

var currentPage = '{{ current_page|default("") }}';
var userToken = '{{ user_token }}';

// Функция для отображения уведомлений
function showAlert(type, message) {
    var alertClass = 'alert-' + type;
    var iconClass = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    
    var alert = '<div class="alert ' + alertClass + ' alert-dismissible">';
    alert += '<i class="fa ' + iconClass + '"></i> ' + message;
    alert += '<button type="button" class="close" data-dismiss="alert">&times;</button>';
    alert += '</div>';
    
    $('#alert-container').html(alert);
    
    // Автоматически скрыть через 5 секунд
    setTimeout(function() {
        $('#alert-container .alert').alert('close');
    }, 5000);
}

// Загрузка модулей для текущей страницы
function loadModules() {
    var url = '';
    
    switch(currentPage) {
        case 'store':
            url = ajaxUrls.getStoreModules;
            break;
        case 'featured':
            url = ajaxUrls.getFeaturedModules;
            break;
        case 'popular':
            url = ajaxUrls.getPopularModules;
            break;
        case 'newest':
            url = ajaxUrls.getNewestModules;
            break;
        default:
            return;
    }
    
    if (!url) {
        $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка</h3><p>URL для загрузки модулей не найден</p></div>');
        return;
    }
    
    $.ajax({
        url: url,
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка загрузки</h3><p>' + json.error + '</p></div>');
            } else if (json.modules) {
                renderModules(json.modules, currentPage);
            } else {
                $('#modules-container').html('<div class="no-modules"><i class="fa fa-puzzle-piece"></i><h3>Модули не найдены</h3><p>Нет доступных модулей в данной категории</p></div>');
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            console.log('AJAX Error:', xhr.status, thrownError);
            $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка подключения</h3><p>Не удалось загрузить список модулей с сервера. Код ошибки: ' + xhr.status + '</p></div>');
        }
    });
}

// Поиск модулей
function searchModules() {
    var query = $('#search-input').val();
    var category = $('#search-category').val();
    var sort = $('#search-sort').val();
    var price = $('#search-price').val();
    
    if (!query.trim()) {
        showAlert('warning', 'Введите поисковый запрос');
        return;
    }
    
    $('#modules-container').html('<div class="text-center loading-content"><i class="fa fa-spinner fa-spin fa-2x"></i><p>Поиск модулей...</p></div>');
    
    // Определяем URL для поиска в зависимости от текущей страницы
    var searchUrl;
    if (currentPage === 'store') {
        // Для страницы "Магазин модулей" используем поиск во внешнем API
        searchUrl = ajaxUrls.searchModules.replace('/searchModules', '/searchStoreModules');
    } else {
        // Для других страниц используем обычный поиск
        searchUrl = ajaxUrls.searchModules;
    }
    
    $.ajax({
        url: searchUrl,
        type: 'POST',
        data: {
            query: query,
            category: category,
            sort: sort,
            price: price,
            user_token: userToken
        },
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка поиска</h3><p>' + json.error + '</p></div>');
            } else if (json.modules) {
                renderModules(json.modules, 'search');
            } else {
                $('#modules-container').html('<div class="no-modules"><i class="fa fa-puzzle-piece"></i><h3>Модули не найдены</h3><p>По вашему запросу ничего не найдено</p></div>');
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            $('#modules-container').html('<div class="no-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка поиска</h3><p>Не удалось выполнить поиск модулей</p></div>');
        }
    });
}

// Отображение модулей
function renderModules(modules, category) {
    var html = '';
    
    if (modules.length === 0) {
        html = '<div class="no-modules"><i class="fa fa-puzzle-piece"></i><h3>Модули не найдены</h3><p>Нет доступных модулей в данной категории</p></div>';
    } else {
        html += '<div class="modules-grid">';
        
        modules.forEach(function(module) {
            var cardClass = 'module-card';
            var moduleInfo = {
                code: module.code || '',
                name: module.name || '',
                module_name: module.name || '',
                version: module.version || '',
                author: module.author || '',
                description: module.description || '',
                category: module.category || 'module'
            };
            var moduleInfoPayload = encodeURIComponent(JSON.stringify(moduleInfo));

            if (category === 'featured' || module.featured) {
                cardClass += ' featured';
            }
            
            html += '<div class="' + cardClass + '">';
            
            html += '<div class="pw-plugin-card-top">';
            html += '<div class="pw-plugin-card-title">';
            html += '<h3>' + (module.name || 'Неизвестный модуль') + ' <span style="font-weight: normal; font-size: 12px; color: #8c8f94;">v' + (module.version || '1.0') + '</span></h3>';
            html += '</div>';
            html += '<div class="pw-plugin-card-desc">';
            html += '<p>' + (module.description || 'Описание отсутствует') + '</p>';
            html += '</div>';
            if (module.author) {
                html += '<p style="font-size: 13px; color: #3c434a;">Автор: ' + module.author + '</p>';
            }
            html += '</div>';
            
            html += '<div class="pw-plugin-card-bottom">';
            html += '<div class="pw-plugin-action">';
            
            if (module.installed) {
                if (module.update_available) {
                    html += '<button class="install-btn update-available" data-code="' + (module.code || '') + '" data-url="' + (module.download_url || '') + '" data-version="' + (module.version || '') + '" data-module-info="' + moduleInfoPayload + '" style="border-color: #d63638; color: #d63638;">';
                    html += 'Обновить до v' + (module.version || '');
                    html += '</button>';
                } else {
                    html += '<button class="install-btn installed" disabled>Установлен</button>';
                }
            } else {
                html += '<button class="install-btn" data-code="' + (module.code || '') + '" data-url="' + (module.download_url || '') + '" data-version="' + (module.version || '') + '" data-module-info="' + moduleInfoPayload + '">';
                html += 'Установить';
                html += '</button>';
            }
            html += '</div>';

            html += '<div class="module-meta-info">';
            if (module.rating) {
                html += '<span>★ ' + module.rating + '</span>';
            }
            if (module.downloads) {
                html += '<span>' + module.downloads + '+ скачиваний</span>';
            }
            html += '</div>';
            html += '</div>';
            html += '</div>';
        });
        
        html += '</div>';
    }
    
    $('#modules-container').html(html);
}

// Установка/обновление модуля
function installModule(moduleCode, downloadUrl, moduleVersion, serverModuleInfo, buttonElement, isUpdate) {
    if (!moduleCode || !downloadUrl) {
        showAlert('danger', 'Недостаточно данных для установки модуля');
        return;
    }
    
    var originalText = $(buttonElement).html();
    var actionText = isUpdate ? 'Обновление' : 'Установка';
    var actionTextLower = isUpdate ? 'обновления' : 'установки';
    
    $.ajax({
        url: ajaxUrls.installModule,
        type: 'POST',
        data: {
            module_code: moduleCode,
            version: moduleVersion || '',
            server_module_info: JSON.stringify(serverModuleInfo || {}),
            download_url: downloadUrl,
            user_token: userToken
        },
        dataType: 'json',
        beforeSend: function() {
            $(buttonElement).prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> ' + actionText + '...');
        },
        success: function(json) {
            if (json.success) {
                showAlert('success', json.success);
                $(buttonElement).removeClass('update-available').addClass('installed').html('<i class="fa fa-check"></i> Установлен');
            } else if (json.error) {
                showAlert('danger', json.error);
                $(buttonElement).prop('disabled', false).html(originalText);
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            showAlert('danger', 'Ошибка ' + actionTextLower + ' модуля: ' + thrownError);
            $(buttonElement).prop('disabled', false).html(originalText);
        }
    });
}

// Обработчики событий
$(document).ready(function() {
    // Автоматически загружаем модули для текущей страницы (кроме поиска и установленных)
    if (currentPage && currentPage !== 'search' && currentPage !== 'installed') {
        loadModules();
    }
    
    // Кнопка обновления списка
    $('#button-refresh').on('click', function() {
        var button = $(this);
        button.button('loading');
        
        if (currentPage === 'search') {
            // Для поиска повторяем последний поиск
            searchModules();
        } else {
            loadModules();
        }
        
        setTimeout(function() {
            button.button('reset');
        }, 1000);
    });
    
    // Поиск модулей
    $('#search-button').on('click', function() {
        searchModules();
    });
    
    $('#search-input').on('keypress', function(e) {
        if (e.which === 13) {
            searchModules();
        }
    });
    
    // Установка/обновление модуля
    $(document).on('click', '.install-btn:not(.installed)', function(e) {
        e.preventDefault();
        var moduleCode = $(this).data('code');
        var downloadUrl = $(this).data('url');
        var moduleVersion = $(this).data('version');
        var moduleInfoPayload = $(this).attr('data-module-info') || '';
        var serverModuleInfo = {};
        if (moduleInfoPayload) {
            try {
                serverModuleInfo = JSON.parse(decodeURIComponent(moduleInfoPayload));
            } catch (e) {
                serverModuleInfo = {};
            }
        }
        var isUpdate = $(this).hasClass('update-available');
        installModule(moduleCode, downloadUrl, moduleVersion, serverModuleInfo, this, isUpdate);
    });
});

// ==================== Установленные модули ====================
if (currentPage === 'installed') {

    function loadSettings() {
        $.ajax({
            url: ajaxUrls.settings, dataType: 'json',
            success: function(json) {
                $('#input-server').val(json.module_gdt_updater_server || '');
                $('#input-api-key').val(json.module_gdt_updater_api_key || '');
                $('#input-status').val(json.module_gdt_updater_status || '0');
            },
            error: function() { showAlert('danger', 'Ошибка загрузки настроек'); }
        });
    }

    function saveSettings() {
        $.ajax({
            url: ajaxUrls.saveSettings, type: 'POST',
            data: $('#form-settings').serialize(),
            dataType: 'json',
            success: function(json) {
                if (json.success) {
                    showAlert('success', json.success);
                    $('#modal-settings').modal('hide');
                    setTimeout(function() { location.reload(); }, 1000);
                } else if (json.error) { showAlert('danger', json.error); }
            },
            error: function() { showAlert('danger', 'Ошибка сохранения настроек'); }
        });
    }

    function updateDeleteButtonState() {
        var n = $('.module-checkbox:checked').not('#select-all-modules').length;
        $('#button-delete-selected').prop('disabled', n === 0);
        $('#button-delete-selected').html('<i class="fa fa-trash"></i> Удалить выбранные' + (n > 0 ? ' (' + n + ')' : ''));
    }

    function showDeleteConfirmation(modules, isMultiple) {
        if (isMultiple) {
            $('#delete-message').text('Вы уверены, что хотите удалить ' + modules.length + ' модуль(ей)?');
            $('#modules-to-delete').show();
            $('#delete-modules-list').empty();
            modules.forEach(function(m) { $('#delete-modules-list').append('<li>' + m.name + ' (' + m.code + ')</li>'); });
        } else {
            $('#delete-message').text('Вы уверены, что хотите удалить модуль "' + modules[0].name + '"?');
            $('#modules-to-delete').hide();
        }
        $('#modal-delete-confirm').data('modules', modules).data('isMultiple', isMultiple).modal('show');
    }

    function deleteSingleModule(module) {
        $.ajax({
            url: module.url, type: 'GET', dataType: 'json',
            beforeSend: function() { showAlert('info', 'Удаление "' + module.name + '"...'); },
            success: function(r) {
                if (r.success) {
                    showAlert('success', r.success);
                    $('tr.pw-module-row[data-code="' + module.code + '"]').fadeOut(function() { $(this).remove(); });
                } else if (r.error) { showAlert('danger', r.error); }
            },
            error: function(xhr, s, err) { showAlert('danger', 'Ошибка удаления: ' + err); }
        });
    }

    function deleteMultipleModules(modules) {
        var codes = modules.map(function(m) { return m.code; });
        $.ajax({
            url: ajaxUrls.deleteMultiple, type: 'POST',
            data: { modules: codes },
            dataType: 'json',
            beforeSend: function() { showAlert('info', 'Удаление модулей...'); },
            success: function(r) {
                if (r.success) {
                    showAlert('success', r.success);
                    codes.forEach(function(c) { $('tr.pw-module-row[data-code="' + c + '"]').fadeOut(function() { $(this).remove(); }); });
                } else if (r.error) { showAlert('danger', r.error); }
                setTimeout(function() { $('.module-checkbox').prop('checked', false); updateDeleteButtonState(); }, 500);
            },
            error: function(xhr, s, err) { showAlert('danger', 'Ошибка: ' + err); }
        });
    }

    $(document).ready(function() {

        $('#button-settings').on('click', function() { loadSettings(); $('#modal-settings').modal('show'); });
        $('#button-save-settings').on('click', function() { saveSettings(); });

        $('#button-check').on('click', function() {
            var btn = $(this);
            $.ajax({
                url: ajaxUrls.checkUpdates, dataType: 'json',
                beforeSend: function() { btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Проверка...'); },
                complete:   function() { btn.prop('disabled', false).html('<i class="fa fa-refresh"></i> Проверить обновления'); },
                success: function(json) {
                    if (json.error) { showAlert('danger', json.error); }
                    else if (json.success) { showAlert('success', json.success); setTimeout(function() { location.reload(); }, 1000); }
                },
                error: function(xhr, s, err) { showAlert('danger', 'Ошибка: ' + err); }
            });
        });

        $(document).on('click', '.update-module', function(e) {
            e.preventDefault();
            var el = this, url = $(el).data('url'), orig = $(el).html();
            if (!url) { showAlert('danger', 'URL для обновления не найден'); return; }
            $.ajax({
                url: url, dataType: 'json',
                beforeSend: function() { $(el).html('<i class="fa fa-spinner fa-spin"></i> Обновление...').addClass('disabled'); },
                success: function(json) {
                    if (json.error) { showAlert('danger', json.error); $(el).html(orig).removeClass('disabled'); }
                    else if (json.success) { showAlert('success', json.success); setTimeout(function() { location.reload(); }, 2000); }
                },
                error: function(xhr, s, err) { showAlert('danger', 'Ошибка: ' + err); $(el).html(orig).removeClass('disabled'); }
            });
        });

        $(document).on('click', '.auto-update-link', function(e) {
            e.preventDefault();
            var el = this, code = $(el).data('code'), cur = $(el).data('current'), next = cur === '1' ? '0' : '1', orig = $(el).html();
            $.ajax({
                url: ajaxUrls.toggleAutoUpdate, type: 'POST',
                data: { module_code: code, auto_update: next, user_token: userToken },
                dataType: 'json',
                beforeSend: function() { $(el).addClass('disabled').html('<i class="fa fa-spinner fa-spin"></i>'); },
                success: function(json) {
                    $(el).removeClass('disabled');
                    if (json.success) {
                        $(el).data('current', next);
                        $(el).html(next === '1'
                            ? '<span style="color:#0071a1"><i class="fa fa-toggle-on"></i> Включено</span>'
                            : '<span style="color:#2271b1"><i class="fa fa-toggle-off"></i> Включить</span>');
                        showAlert('success', 'Автообновление обновлено');
                    } else if (json.error) { $(el).html(orig); showAlert('danger', json.error); }
                },
                error: function(xhr, s, err) { $(el).removeClass('disabled').html(orig); showAlert('danger', 'Ошибка: ' + err); }
            });
        });

        $('#select-all-modules').on('change', function() {
            $('.module-checkbox').not('#select-all-modules').prop('checked', $(this).is(':checked'));
            updateDeleteButtonState();
        });

        $(document).on('change', '.module-checkbox', function() {
            if (!$(this).is('#select-all-modules')) {
                var total = $('.module-checkbox').not('#select-all-modules').length;
                var checked = $('.module-checkbox:checked').not('#select-all-modules').length;
                $('#select-all-modules').prop('checked', total === checked);
                updateDeleteButtonState();
            }
        });

        $('#button-delete-selected').on('click', function() {
            var selected = [];
            $('.module-checkbox:checked').not('#select-all-modules').each(function() {
                var code = $(this).data('code');
                var row  = $('tr.pw-module-row[data-code="' + code + '"]');
                var name = row.find('.pw-module-title').text().trim();
                var url  = row.find('.delete-module').data('url');
                selected.push({ code: code, name: name, url: url });
            });
            if (selected.length > 0) { showDeleteConfirmation(selected, true); }
        });

        $(document).on('click', '.delete-module', function(e) {
            e.preventDefault();
            showDeleteConfirmation([{ code: $(this).data('code'), name: $(this).data('name'), url: $(this).data('url') }], false);
        });

        $('#button-confirm-delete').on('click', function() {
            var modal = $('#modal-delete-confirm');
            var modules = modal.data('modules');
            var isMultiple = modal.data('isMultiple');
            modal.modal('hide');
            if (isMultiple) { deleteMultipleModules(modules); } else { deleteSingleModule(modules[0]); }
        });

        $('#pw-filter-modules').on('input', function() {
            var val = $(this).val().toLowerCase();
            $('#modules-tbody tr').each(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(val) > -1);
            });
        });

    }); // end document.ready (installed)

} // end if (currentPage === 'installed')
