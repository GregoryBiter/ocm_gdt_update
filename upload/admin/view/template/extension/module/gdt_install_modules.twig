{{ header }}{{ column_left }}
<div id="content" x-data="gdtInstallModules()">
<script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js" defer></script>
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        {% if current_page == 'installed' %}
        <button type="button" @click="confirmDeleteMultiple()" class="btn btn-danger" :disabled="selectedModules.length === 0">
          <i class="fa fa-trash"></i> Удалить выбранные <span x-show="selectedModules.length > 0" x-text="'(' + selectedModules.length + ')'"></span>
        </button>
        <button type="button" @click="showSettings()" class="btn btn-default"><i class="fa fa-cog"></i> Настройки</button>
        <button type="button" @click="checkUpdates()" class="btn btn-primary" :disabled="isCheckingUpdates">
          <i class="fa" :class="isCheckingUpdates ? 'fa-spinner fa-spin' : 'fa-refresh'"></i> 
          <span x-text="isCheckingUpdates ? 'Проверка...' : 'Проверить обновления'"></span>
        </button>
        {% else %}
        <button type="button" @click="refreshList()" class="btn btn-default" :disabled="isLoading">
          <i class="fa" :class="isLoading ? 'fa-spinner fa-spin' : 'fa-refresh'"></i> 
          <span x-text="isLoading ? 'Загрузка...' : 'Обновить список'"></span>
        </button>
        {% endif %}
        <a href="{{ back }}" data-toggle="tooltip" title="Назад" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ page_title|default('Модули') }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <!-- Сообщения -->
    <div id="alert-container"></div>

    {% if current_page == 'installed' %}
    <!-- Модальное окно настроек -->
    <div class="modal fade" id="modal-settings" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span></button>
            <h4 class="modal-title">Настройки модуля</h4>
          </div>
          <div class="modal-body">
            <form @submit.prevent="saveSettings()">
              <div class="form-group">
                <label>URL сервера обновлений</label>
                <input type="text" x-model="settings.server" class="form-control" />
              </div>
              <div class="form-group">
                <label>API-ключ</label>
                <input type="text" x-model="settings.api_key" class="form-control" />
              </div>
              <div class="form-group">
                <label>Статус</label>
                <select x-model="settings.status" class="form-control">
                  <option value="1">Включён</option>
                  <option value="0">Отключён</option>
                </select>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Отмена</button>
            <button type="button" class="btn btn-primary" @click="saveSettings()" :disabled="isSavingSettings">
              <i class="fa" :class="isSavingSettings ? 'fa-spinner fa-spin' : ''"></i> Сохранить
            </button>
          </div>
        </div>
      </div>
    </div>
    <!-- Модальное окно подтверждения удаления -->
    <div class="modal fade" id="modal-delete-confirm" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal"><span aria-hidden="true">&times;</span></button>
            <h4 class="modal-title"><i class="fa fa-warning text-danger"></i> Подтверждение удаления</h4>
          </div>
          <div class="modal-body">
            <div class="alert alert-warning"><i class="fa fa-exclamation-triangle"></i> <strong>Внимание!</strong> Удаление модуля необратимо.</div>
            <p x-text="deleteModal.message"></p>
            <div x-show="deleteModal.isMultiple">
              <strong>Модули для удаления:</strong>
              <ul>
                <template x-for="m in deleteModal.modules" :key="m.code">
                  <li x-text="m.name + ' (' + m.code + ')'"></li>
                </template>
              </ul>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Отмена</button>
            <button type="button" class="btn btn-danger" @click="confirmDelete()" :disabled="isDeleting">
              <i class="fa" :class="isDeleting ? 'fa-spinner fa-spin' : 'fa-trash'"></i> Удалить
            </button>
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    <!-- Навигация между страницами -->
    <div class="panel panel-default" style="margin-bottom:15px;">
      <div class="panel-body" style="padding:0 15px;">
        <ul class="nav nav-tabs gdt-nav-tabs">
          <li class="{% if current_page == 'installed' %}active{% endif %}">
            <a href="{{ installed_url }}"><i class="fa fa-plug"></i> Установленные</a>
          </li>
          <li class="{% if current_page == 'store' %}active{% endif %}">
            <a href="{{ store_url }}"><i class="fa fa-shopping-cart"></i> Магазин</a>
          </li>
          <li class="{% if current_page == 'featured' %}active{% endif %}">
            <a href="{{ featured_url }}"><i class="fa fa-star"></i> Рекомендуемые</a>
          </li>
          <li class="{% if current_page == 'popular' %}active{% endif %}">
            <a href="{{ popular_url }}"><i class="fa fa-trophy"></i> Популярные</a>
          </li>
          <li class="{% if current_page == 'newest' %}active{% endif %}">
            <a href="{{ newest_url }}"><i class="fa fa-clock-o"></i> Новые</a>
          </li>
          <li class="{% if current_page == 'search' %}active{% endif %}">
            <a href="{{ search_url }}"><i class="fa fa-search"></i> Поиск</a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Контент страницы -->
    <div class="panel panel-default pw-panel">
      <div class="panel-heading pw-panel-heading">
        <h3 class="panel-title">
          {% if current_page == 'installed' %}
            <i class="fa fa-plug"></i> {{ page_title|default('Установленные модули') }}
          {% elseif current_page == 'store' %}
            <i class="fa fa-shopping-cart"></i> {{ page_title|default('Магазин модулей') }}
          {% elseif current_page == 'featured' %}
            <i class="fa fa-star"></i> {{ page_title|default('Рекомендуемые') }}
          {% elseif current_page == 'popular' %}
            <i class="fa fa-trophy"></i> {{ page_title|default('Популярные') }}
          {% elseif current_page == 'newest' %}
            <i class="fa fa-clock-o"></i> {{ page_title|default('Новые') }}
          {% elseif current_page == 'search' %}
            <i class="fa fa-search"></i> {{ page_title|default('Поиск') }}
          {% else %}
            <i class="fa fa-puzzle-piece"></i> {{ page_title|default('Установка модулей') }}
          {% endif %}
        </h3>
        {% if current_page == 'installed' %}
        <div class="pw-search">
          <input type="text" class="form-control" id="pw-filter-modules" placeholder="Поиск...">
        </div>
        {% endif %}
      </div>
      <div class="panel-body">
        {% if current_page == 'installed' %}
          {% if modules is empty %}
            <div class="pw-no-modules">
              <i class="fa fa-inbox"></i>
              <h3>Нет установленных модулей</h3>
              <p>Перейдите в каталог, чтобы найти и установить новые модули.</p>
              <a href="{{ store_url }}" class="btn btn-primary" style="margin-top:15px;">Посмотреть каталог</a>
            </div>
          {% else %}
            <table class="table pw-modules-table">
              <thead>
                <tr>
                  <th class="col-cb"><input type="checkbox" @change="toggleSelectAll()" :checked="allSelected"></th>
                  <th class="col-name">Модуль</th>
                  <th class="col-desc">Описание</th>
                  <th class="col-auto">Автообновление</th>
                </tr>
              </thead>
              <tbody id="modules-tbody">
                <template x-for="module in filteredModules" :key="module.code">
                  <tr class="pw-module-row" :class="module.has_update ? 'has-update' : ''">
                    <td class="col-cb">
                      <input type="checkbox" :value="module.code" x-model="selectedModules">
                    </td>
                    <td class="col-name">
                      <h3 class="pw-module-title" x-text="module.name"></h3>
                      <div class="pw-row-actions">
                        <template x-if="module.settings_url">
                          <span><a :href="module.settings_url">Настройки</a> | </span>
                        </template>
                        <template x-if="module.has_update">
                          <span><a href="#" @click.prevent="updateModule(module)" style="color:#d63638">Обновить</a> | </span>
                        </template>
                        <template x-if="module.delete_url">
                          <span><a href="#" @click.prevent="confirmDeleteSingle(module)" style="color:#b32d2e">Удалить</a></span>
                        </template>
                      </div>
                    </td>
                    <td class="col-desc">
                      <div class="pw-module-description"><p x-text="module.description"></p></div>
                      <div class="pw-module-meta">
                        <span x-text="'Версия ' + module.version"></span>
                        <template x-if="module.author">
                          <span> | Автор: 
                            <template x-if="module.author_url">
                              <a :href="module.author_url" target="_blank" x-text="module.author"></a>
                            </template>
                            <template x-if="!module.author_url">
                              <span x-text="module.author"></span>
                            </template>
                          </span>
                        </template>
                        <template x-if="module.has_update">
                          <div class="pw-update-notice">
                            <strong x-text="'Доступна новая версия: ' + module.new_version"></strong>. 
                            <a href="#" @click.prevent="updateModule(module)">Обновить сейчас</a>
                          </div>
                        </template>
                      </div>
                    </td>
                    <td class="col-auto">
                      <a href="#" @click.prevent="toggleAutoUpdate(module)" class="auto-update-link">
                        <span x-show="module.auto_update" style="color:#0071a1"><i class="fa fa-toggle-on"></i> Включено</span>
                        <span x-show="!module.auto_update" style="color:#2271b1"><i class="fa fa-toggle-off"></i> Включить</span>
                      </a>
                    </td>
                  </tr>
                </template>
              </tbody>
            </table>
          {% endif %}
          <div id="update-results"></div>
        {% else %}
          {% if page_description %}
          <p class="text-muted">{{ page_description }}</p>
          {% endif %}

          {% if current_page == 'search' or current_page == 'store' %}
          <div class="search-form">
            <div class="row">
              <div class="col-md-8">
                <input type="text" x-model="catalog.query" @keyup.enter="searchModules()" class="form-control" placeholder="Введите название модуля или ключевые слова...">
              </div>
              <div class="col-md-4">
                <button type="button" @click="searchModules()" class="btn btn-primary btn-block" :disabled="isLoading">
                  <i class="fa" :class="isLoading ? 'fa-spinner fa-spin' : 'fa-search'"></i> {{ current_page == 'store' ? 'Поиск в магазине' : 'Найти модули' }}
                </button>
              </div>
            </div>
            <div class="row" style="margin-top: 15px;">
              <div class="col-md-4">
                <select x-model="catalog.category" class="form-control">
                  <option value="">Все категории</option>
                  <option value="ecommerce">Электронная коммерция</option>
                  <option value="shipping">Доставка</option>
                  <option value="payment">Платежи</option>
                  <option value="seo">SEO</option>
                  <option value="analytics">Аналитика</option>
                  <option value="marketing">Маркетинг</option>
                  <option value="design">Дизайн</option>
                  <option value="tools">Инструменты</option>
                </select>
              </div>
              <div class="col-md-4">
                <select x-model="catalog.sort" class="form-control">
                  <option value="relevance">По релевантности</option>
                  <option value="popularity">По популярности</option>
                  <option value="rating">По рейтингу</option>
                  <option value="date">По дате</option>
                  <option value="name">По названию</option>
                </select>
              </div>
              <div class="col-md-4">
                <select x-model="catalog.price" class="form-control">
                  <option value="">Любая цена</option>
                  <option value="free">Бесплатные</option>
                  <option value="paid">Платные</option>
                </select>
              </div>
            </div>
          </div>
          {% endif %}

          <div id="modules-container">
            <template x-if="isLoading">
              <div class="text-center loading-content">
                <i class="fa fa-spinner fa-spin fa-2x"></i>
                <p x-text="'Загрузка ' + pageTitle.toLowerCase() + '...'"></p>
              </div>
            </template>

            <template x-if="!isLoading && modules.length === 0">
              <div class="no-modules text-center">
                <template x-if="currentPage === 'search' && !catalog.query">
                  <div>
                    <i class="fa fa-search fa-2x"></i>
                    <p>Введите поисковый запрос для поиска модулей</p>
                  </div>
                </template>
                <template x-if="!(currentPage === 'search' && !catalog.query)">
                  <div>
                    <i class="fa fa-puzzle-piece fa-2x"></i>
                    <h3>Модули не найдены</h3>
                    <p>Нет доступных модулей в данной категории</p>
                  </div>
                </template>
              </div>
            </template>

            <template x-if="!isLoading && modules.length > 0">
              <div class="modules-grid">
                <template x-for="module in modules" :key="module.code">
                  <div class="module-card" :class="(currentPage === 'featured' || module.featured) ? 'featured' : ''">
                    <div class="pw-plugin-card-top">
                      <div class="pw-plugin-card-title">
                        <h3><span x-text="module.name || 'Неизвестный модуль'"></span> <span style="font-weight: normal; font-size: 12px; color: #8c8f94;" x-text="'v' + (module.version || '1.0')"></span></h3>
                      </div>
                      <div class="pw-plugin-card-desc">
                        <p x-text="module.description || 'Описание отсутствует'"></p>
                      </div>
                      <template x-if="module.author">
                        <p style="font-size: 13px; color: #3c434a;" x-text="'Автор: ' + module.author"></p>
                      </template>
                    </div>
                    <div class="pw-plugin-card-bottom">
                      <div class="pw-plugin-action">
                        <template x-if="module.installed">
                          <div>
                            <template x-if="module.update_available">
                              <button @click="install(module)" class="install-btn update-available" style="border-color: #d63638; color: #d63638;" :disabled="module.isInstalling">
                                <i x-show="module.isInstalling" class="fa fa-spinner fa-spin"></i>
                                <span x-text="module.isInstalling ? 'Обновление...' : 'Обновить до v' + (module.version || '')"></span>
                              </button>
                            </template>
                            <template x-if="!module.update_available">
                              <button class="install-btn installed" disabled>Установлен</button>
                            </template>
                          </div>
                        </template>
                        <template x-if="!module.installed">
                          <button @click="install(module)" class="install-btn" :disabled="module.isInstalling">
                            <i x-show="module.isInstalling" class="fa fa-spinner fa-spin"></i>
                            <span x-text="module.isInstalling ? 'Установка...' : 'Установить'"></span>
                          </button>
                        </template>
                      </div>
                      <div class="module-meta-info">
                        <template x-if="module.rating">
                          <span x-text="'★ ' + module.rating"></span>
                        </template>
                        <template x-if="module.downloads">
                          <span x-text="module.downloads + '+ скачиваний'"></span>
                        </template>
                      </div>
                    </div>
                  </div>
                </template>
              </div>
            </template>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
/* WordPress-styled App Store CSS */
.pw-panel { border: none; box-shadow: 0 1px 1px rgba(0,0,0,.04); border-radius: 4px; }
.pw-panel-heading { background: #fff !important; padding: 15px 20px; border-bottom: 1px solid #ccd0d4; }
.pw-panel-heading .panel-title { font-size: 18px; font-weight: 400; color: #1d2327; }

/* Filter Navigation */
.gdt-nav-tabs { border-bottom: 1px solid #ccd0d4; margin-bottom: 0; padding-left: 0; }
.gdt-nav-tabs > li > a { border: none !important; color: #2271b1; padding: 10px 15px; font-size: 14px; font-weight: 400; background: transparent !important; }
.gdt-nav-tabs > li > a:hover { color: #135e96; background: #f8f9fa !important; }
.gdt-nav-tabs > li.active > a, .gdt-nav-tabs > li.active > a:hover, .gdt-nav-tabs > li.active > a:focus {
    color: #1d2327;
    font-weight: 600;
    border-bottom: 3px solid #2271b1 !important;
    background: #fff !important;
}

/* Installed Modules Table */
.pw-panel-heading { display: flex; justify-content: space-between; align-items: center; }
.pw-search { max-width: 250px; }
.pw-search input { height: 32px; font-size: 13px; border: 1px solid #8c8f94; border-radius: 4px; }
.pw-modules-table { margin-bottom: 0; }
.pw-modules-table thead th { border-bottom: 1px solid #ccd0d4 !important; color: #2c3338; font-size: 14px; font-weight: 400; padding: 8px 10px; }
.pw-modules-table tbody tr { border-top: 1px solid #c3c4c7; }
.pw-modules-table tbody tr:last-child { border-bottom: 1px solid #c3c4c7; }
.pw-modules-table tbody tr.has-update { background-color: #fcf0f1; }
.pw-modules-table tbody td { padding: 15px 10px; vertical-align: top; border-top: none !important; }
.col-cb { width: 40px; text-align: center; }
.col-name { width: 22%; }
.col-desc { width: 58%; }
.col-auto { width: 15%; }
.pw-module-title { font-size: 14px; font-weight: 600; margin: 0 0 4px; color: #2271b1; }
.pw-row-actions { visibility: hidden; font-size: 13px; padding: 2px 0 0; }
.pw-module-row:hover .pw-row-actions { visibility: visible; }
.pw-row-actions a { color: #2271b1; text-decoration: none; }
.pw-row-actions a:hover { text-decoration: underline; }
.pw-module-description p { margin: 0 0 6px; font-size: 13px; line-height: 1.5; color: #3c434a; }
.pw-module-meta { font-size: 12px; color: #a7aaad; }
.pw-module-meta a { color: #3c434a; text-decoration: none; }
.pw-module-meta a:hover { color: #2271b1; }
.pw-update-notice { background: #fcf0f1; border-left: 4px solid #d63638; padding: 8px 12px; margin-top: 8px; font-size: 13px; color: #1d2327; }
.pw-update-notice a { color: #d63638; }
.pw-no-modules { text-align: center; padding: 60px 20px; }
.pw-no-modules i { font-size: 48px; color: #c3c4c7; margin-bottom: 15px; display: block; }
.auto-update-link { display: inline-block; padding: 4px 0; text-decoration: none; font-size: 13px; }
.auto-update-link:hover { text-decoration: underline; }

/* Modules Grid */
.modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 20px;
}

.module-card {
    background: #fff;
    border: 1px solid #c3c4c7;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.module-card.featured { border-left: 4px solid #b32d2e; }

/* Top Section: Icon, Title, Author, Description */
.pw-plugin-card-top {
    padding: 20px;
    border-bottom: 1px solid #f0f0f1;
    min-height: 180px;
}

.pw-plugin-card-title {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
}
.pw-plugin-card-title h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.4;
    color: #1d2327;
}

.pw-plugin-card-desc {
    color: #3c434a;
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: 15px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

/* Bottom Section: Installs, Rating, Install Button */
.pw-plugin-card-bottom {
    background: #f6f7f7;
    padding: 15px 20px;
    border-top: 1px solid #f0f0f1;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.pw-plugin-action { flex: 1; }
.install-btn {
    background: #f6f7f7;
    border: 1px solid #2271b1;
    color: #2271b1;
    padding: 4px 12px;
    border-radius: 3px;
    font-size: 13px;
    text-decoration: none;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s;
}
.install-btn:hover { background: #f0f0f1; color: #135e96; border-color: #135e96; }
.install-btn.installed { background: #f6f7f7; color: #2c3338; border-color: #8c8f94; cursor: default; }
.install-btn.update-available { background: #fff3cd; border-color: #e0a800; color: #856404; }
.install-btn.update-available:hover { background: #ffe69c; }

.module-meta-info {
    font-size: 12px;
    color: #8c8f94;
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.search-form { padding: 20px 0; }
.loading-content { text-align: center; padding: 60px; color: #8c8f94; }

.no-modules { text-align: center; padding: 60px 20px; color: #8c8f94; }
.no-modules i { font-size: 48px; color: #dcdcde; margin-bottom: 15px; }
.no-modules h3 { font-size: 18px; color: #3c434a; margin-bottom: 10px; }

@media (max-width: 768px) {
    .modules-grid { grid-template-columns: 1fr; }
    .pw-modules-table thead { display: none; }
    .pw-modules-table tbody td { display: block; width: 100% !important; border: none !important; padding: 8px 10px; }
    .pw-row-actions { visibility: visible; }
    .col-cb, .col-auto { width: auto; }
}
</style>

<script type="text/javascript"><!--
function gdtInstallModules() {
    return {
        currentPage: '{{ current_page|default("") }}',
        pageTitle: '{{ page_title|default("Модули") }}',
        userToken: '{{ user_token }}',
        modules: {% if current_page == 'installed' %}{{ modules|json_encode }}{% else %}[]{% endif %},
        isLoading: false,
        isCheckingUpdates: false,
        isSavingSettings: false,
        isDeleting: false,
        filterQuery: '',
        selectedModules: [],
        catalog: {
            query: '',
            category: '',
            sort: 'relevance',
            price: ''
        },
        settings: {
            server: '',
            api_key: '',
            status: '1'
        },
        deleteModal: {
            message: '',
            modules: [],
            isMultiple: false
        },
        ajaxUrls: {
            getFeatured:   '{{ get_modules_url|default("") }}',
            getPopular:    '{{ get_modules_url|default("") }}',
            getNewest:     '{{ get_modules_url|default("") }}',
            getStore:      '{{ get_modules_url|default("") }}',
            search:        '{{ search_modules_url|default("") }}',
            install:       '{{ install_module_url|default("") }}',
            settings:      '{{ settings_url|default("") }}',
            saveSettings:  '{{ save_settings_url|default("") }}',
            checkUpdates:  '{{ check_updates_url|default("") }}',
            toggleAutoUpdate: '{{ toggle_auto_update_url|default("") }}',
            deleteMultiple: '{{ delete_multiple_url|default("") }}'
        },

        init() {
            if (this.currentPage && this.currentPage !== 'search' && this.currentPage !== 'installed') {
                this.loadModules();
            }
        },

        get filteredModules() {
            if (!this.filterQuery) return this.modules;
            const q = this.filterQuery.toLowerCase();
            return this.modules.filter(m => 
                (m.name && m.name.toLowerCase().includes(q)) || 
                (m.code && m.code.toLowerCase().includes(q)) || 
                (m.description && m.description.toLowerCase().includes(q))
            );
        },

        get allSelected() {
            return this.filteredModules.length > 0 && this.selectedModules.length === this.filteredModules.length;
        },

        toggleSelectAll() {
            if (this.allSelected) {
                this.selectedModules = [];
            } else {
                this.selectedModules = this.filteredModules.map(m => m.code);
            }
        },

        showAlert(type, message) {
            const container = document.getElementById('alert-container');
            const alertClass = 'alert-' + type;
            const iconClass = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
            
            container.innerHTML = `
                <div class="alert ${alertClass} alert-dismissible">
                    <i class="fa ${iconClass}"></i> ${message}
                    <button type="button" class="close" data-dismiss="alert">&times;</button>
                </div>
            `;
            
            setTimeout(() => {
                const alert = container.querySelector('.alert');
                if (alert) $(alert).alert('close');
            }, 5000);
        },

        loadModules() {
            let url = '';
            switch(this.currentPage) {
                case 'store': url = this.ajaxUrls.getStore; break;
                case 'featured': url = this.ajaxUrls.getFeatured; break;
                case 'popular': url = this.ajaxUrls.getPopular; break;
                case 'newest': url = this.ajaxUrls.getNewest; break;
                default: return;
            }
            
            this.isLoading = true;
            fetch(url)
                .then(r => r.json())
                .then(json => {
                    this.isLoading = false;
                    if (json.error) {
                        this.showAlert('danger', json.error);
                    } else {
                        this.modules = (json.modules || []).map(m => ({ ...m, isInstalling: false }));
                    }
                })
                .catch(err => {
                    this.isLoading = false;
                    this.showAlert('danger', 'Ошибка загрузки: ' + err);
                });
        },

        refreshList() {
            if (this.currentPage === 'search') {
                this.searchModules();
            } else {
                this.loadModules();
            }
        },

        searchModules() {
            if (!this.catalog.query.trim()) {
                this.showAlert('warning', 'Введите поисковый запрос');
                return;
            }

            this.isLoading = true;
            const url = this.currentPage === 'store' 
                ? this.ajaxUrls.search.replace('/searchModules', '/searchStoreModules')
                : this.ajaxUrls.search;

            const formData = new FormData();
            formData.append('query', this.catalog.query);
            formData.append('category', this.catalog.category);
            formData.append('sort', this.catalog.sort);
            formData.append('price', this.catalog.price);
            formData.append('user_token', this.userToken);

            fetch(url, { method: 'POST', body: formData })
                .then(r => r.json())
                .then(json => {
                    this.isLoading = false;
                    if (json.error) {
                        this.showAlert('danger', json.error);
                    } else {
                        this.modules = (json.modules || []).map(m => ({ ...m, isInstalling: false }));
                    }
                })
                .catch(err => {
                    this.isLoading = false;
                    this.showAlert('danger', 'Ошибка поиска: ' + err);
                });
        },

        install(module) {
            module.isInstalling = true;
            const isUpdate = module.installed && module.update_available;
            
            const moduleInfo = {
                code: module.code || '',
                name: module.name || '',
                module_name: module.name || '',
                version: module.version || '',
                author: module.author || '',
                description: module.description || '',
                category: module.category || 'module'
            };

            const formData = new FormData();
            formData.append('module_code', module.code);
            formData.append('version', module.version || '');
            formData.append('server_module_info', JSON.stringify(moduleInfo));
            formData.append('download_url', module.download_url || '');
            formData.append('user_token', this.userToken);

            fetch(this.ajaxUrls.install, { method: 'POST', body: formData })
                .then(r => r.json())
                .then(json => {
                    module.isInstalling = false;
                    if (json.success) {
                        this.showAlert('success', json.success);
                        module.installed = true;
                        module.update_available = false;
                    } else if (json.error) {
                        this.showAlert('danger', json.error);
                    }
                })
                .catch(err => {
                    module.isInstalling = false;
                    this.showAlert('danger', 'Ошибка установки: ' + err);
                });
        },

        showSettings() {
            fetch(this.ajaxUrls.settings)
                .then(r => r.json())
                .then(json => {
                    this.settings.server = json.module_gdt_updater_server || '';
                    this.settings.api_key = json.module_gdt_updater_api_key || '';
                    this.settings.status = json.module_gdt_updater_status || '0';
                    $('#modal-settings').modal('show');
                });
        },

        saveSettings() {
            this.isSavingSettings = true;
            const formData = new FormData();
            formData.append('module_gdt_updater_server', this.settings.server);
            formData.append('module_gdt_updater_api_key', this.settings.api_key);
            formData.append('module_gdt_updater_status', this.settings.status);
            formData.append('user_token', this.userToken);

            fetch(this.ajaxUrls.saveSettings, { method: 'POST', body: formData })
                .then(r => r.json())
                .then(json => {
                    this.isSavingSettings = false;
                    if (json.success) {
                        this.showAlert('success', json.success);
                        $('#modal-settings').modal('hide');
                        setTimeout(() => location.reload(), 1000);
                    } else if (json.error) {
                        this.showAlert('danger', json.error);
                    }
                })
                .catch(err => {
                    this.isSavingSettings = false;
                    this.showAlert('danger', 'Ошибка сохранения: ' + err);
                });
        },

        checkUpdates() {
            this.isCheckingUpdates = true;
            fetch(this.ajaxUrls.checkUpdates)
                .then(r => r.json())
                .then(json => {
                    this.isCheckingUpdates = false;
                    if (json.error) {
                        this.showAlert('danger', json.error);
                    } else if (json.success) {
                        this.showAlert('success', json.success);
                        setTimeout(() => location.reload(), 1000);
                    }
                })
                .catch(err => {
                    this.isCheckingUpdates = false;
                    this.showAlert('danger', 'Ошибка: ' + err);
                });
        },

        updateModule(module) {
            // This is for the "Update" link in the installed modules table
            const url = this.urlForUpdate(module);
            if (!url) {
                this.showAlert('danger', 'URL для обновления не найден');
                return;
            }
            
            fetch(url)
                .then(r => r.json())
                .then(json => {
                    if (json.error) {
                        this.showAlert('danger', json.error);
                    } else if (json.success) {
                        this.showAlert('success', json.success);
                        setTimeout(() => location.reload(), 2000);
                    }
                })
                .catch(err => this.showAlert('danger', 'Ошибка: ' + err));
        },

        urlForUpdate(module) {
            // Reconstruct update URL since it depends on the module code
            return `index.php?route=extension/module/gdt_updater/update&user_token=${this.userToken}&code=${module.code}`;
        },

        toggleAutoUpdate(module) {
            const next = module.auto_update ? '0' : '1';
            const formData = new FormData();
            formData.append('module_code', module.code);
            formData.append('auto_update', next);
            formData.append('user_token', this.userToken);

            fetch(this.ajaxUrls.toggleAutoUpdate, { method: 'POST', body: formData })
                .then(r => r.json())
                .then(json => {
                    if (json.success) {
                        module.auto_update = (next === '1');
                        this.showAlert('success', 'Автообновление обновлено');
                    } else if (json.error) {
                        this.showAlert('danger', json.error);
                    }
                });
        },

        confirmDeleteSingle(module) {
            this.deleteModal.isMultiple = false;
            this.deleteModal.message = `Вы уверены, что хотите удалить модуль "${module.name}"?`;
            this.deleteModal.modules = [module];
            $('#modal-delete-confirm').modal('show');
        },

        confirmDeleteMultiple() {
            const selected = this.modules.filter(m => this.selectedModules.includes(m.code));
            this.deleteModal.isMultiple = true;
            this.deleteModal.message = `Вы уверены, что хотите удалить ${selected.length} модуль(ей)?`;
            this.deleteModal.modules = selected;
            $('#modal-delete-confirm').modal('show');
        },

        confirmDelete() {
            this.isDeleting = true;
            $('#modal-delete-confirm').modal('hide');
            
            if (this.deleteModal.isMultiple) {
                const codes = this.deleteModal.modules.map(m => m.code);
                const formData = new FormData();
                codes.forEach(c => formData.append('modules[]', c));
                formData.append('user_token', this.userToken);

                fetch(this.ajaxUrls.deleteMultiple, { method: 'POST', body: formData })
                    .then(r => r.json())
                    .then(json => {
                        this.isDeleting = false;
                        if (json.success) {
                            this.showAlert('success', json.success);
                            this.modules = this.modules.filter(m => !codes.includes(m.code));
                            this.selectedModules = [];
                        } else if (json.error) {
                            this.showAlert('danger', json.error);
                        }
                    });
            } else {
                const module = this.deleteModal.modules[0];
                const url = `index.php?route=extension/module/gdt_updater/delete&user_token=${this.userToken}&code=${module.code}`;
                
                fetch(url)
                    .then(r => r.json())
                    .then(json => {
                        this.isDeleting = false;
                        if (json.success) {
                            this.showAlert('success', json.success);
                            this.modules = this.modules.filter(m => m.code !== module.code);
                        } else if (json.error) {
                            this.showAlert('danger', json.error);
                        }
                    });
            }
        }
    }
}
//--></script>
{{ footer }}
