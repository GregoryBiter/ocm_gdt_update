{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" id="button-upload" class="btn btn-primary"><i class="fa fa-upload"></i> {{ text_upload }}</button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title_modules }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
      </div>
      <div class="panel-body">
        
        <!-- Панель синхронизации модулей -->
        <div class="well">
          <h4><i class="fa fa-refresh"></i> Синхронизация модулей</h4>
          <p>Сканирование и синхронизация модулей из файловой системы (system/modules/*/opencart-module.json)</p>
          <div class="form-group">
            <button type="button" id="button-scan" class="btn btn-info"><i class="fa fa-search"></i> Сканировать модули</button>
            <button type="button" id="button-sync" class="btn btn-success"><i class="fa fa-refresh"></i> Синхронизировать все</button>
          </div>
          <div id="sync-results" style="display: none;">
            <div class="alert alert-info">
              <h5>Найденные модули в файловой системе:</h5>
              <div id="scanned-modules"></div>
            </div>
          </div>
        </div>
        
        <!-- Форма загрузки модуля -->
        <div id="upload-form" class="well" style="display: none;">
          <h4>{{ text_upload_module }}</h4>
          <form enctype="multipart/form-data" id="form-upload">
            <div class="form-group">
              <label class="control-label">{{ entry_file }}</label>
              <input type="file" name="file" id="input-file" class="form-control" accept=".zip" />
              <div class="help-block">{{ help_upload }}</div>
            </div>
            <div class="form-group">
              <button type="submit" class="btn btn-primary">{{ button_upload }}</button>
              <button type="button" id="button-cancel-upload" class="btn btn-default">{{ button_cancel }}</button>
            </div>
          </form>
        </div>
        
        <!-- Список модулей -->
        {% if modules %}
        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <td class="text-center">{{ column_image }}</td>
                <td>{{ column_name }}</td>
                <td>{{ column_version }}</td>
                <td>{{ column_author }}</td>
                <td>{{ column_upload_date }}</td>
                <td class="text-right">{{ column_action }}</td>
              </tr>
            </thead>
            <tbody>
              {% for module in modules %}
              <tr id="module-row-{{ module.code }}">
                <td class="text-center">
                  <i class="fa fa-puzzle-piece fa-2x text-primary"></i>
                </td>
                <td>
                  <strong>{{ module.name }}</strong>
                  <br />
                  <small class="text-muted">{{ module.code }}</small>
                  {% if module.description %}
                  <br />
                  <span class="text-muted">{{ module.description }}</span>
                  {% endif %}
                </td>
                <td>{{ module.version }}</td>
                <td>{{ module.author|default('-') }}</td>
                <td>{{ module.upload_date }}</td>
                <td class="text-right">
                  <div class="btn-group">
                    <button type="button" class="btn btn-info btn-sm" onclick="viewModuleInfo('{{ module.code }}')" data-toggle="tooltip" title="{{ button_info }}">
                      <i class="fa fa-info"></i>
                    </button>
                    <button type="button" class="btn btn-warning btn-sm" onclick="updateModule('{{ module.code }}')" data-toggle="tooltip" title="{{ button_update }}">
                      <i class="fa fa-refresh"></i>
                    </button>
                    <button type="button" class="btn btn-danger btn-sm" onclick="deleteModule('{{ module.code }}')" data-toggle="tooltip" title="{{ button_delete }}">
                      <i class="fa fa-trash"></i>
                    </button>
                  </div>
                </td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% else %}
        <div class="text-center" style="padding: 40px;">
          <i class="fa fa-puzzle-piece fa-4x text-muted"></i>
          <h4 class="text-muted">{{ text_no_modules }}</h4>
          <p class="text-muted">{{ text_no_modules_desc }}</p>
          <button type="button" class="btn btn-primary" onclick="$('#button-upload').click();">
            <i class="fa fa-upload"></i> {{ text_upload_first_module }}
          </button>
        </div>
        {% endif %}
        
      </div>
    </div>
  </div>
</div>

<!-- Модальное окно информации о модуле -->
<div class="modal fade" id="modal-module-info" tabindex="-1" role="dialog">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">&times;</button>
        <h4 class="modal-title">{{ text_module_info }}</h4>
      </div>
      <div class="modal-body" id="module-info-content">
        <!-- Содержимое загружается через AJAX -->
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-default" data-dismiss="modal">{{ button_close }}</button>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
// Показать/скрыть форму загрузки
$('#button-upload').on('click', function() {
    $('#upload-form').slideToggle();
});

$('#button-cancel-upload').on('click', function() {
    $('#upload-form').slideUp();
    $('#form-upload')[0].reset();
});

// Загрузка файла
$('#form-upload').on('submit', function(e) {
    e.preventDefault();
    
    var formData = new FormData(this);
    var button = $(this).find('button[type="submit"]');
    var originalText = button.html();
    
    button.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> {{ text_uploading }}');
    
    $.ajax({
        url: '{{ upload_url }}',
        type: 'POST',
        data: formData,
        processData: false,
        contentType: false,
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#content').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json.error + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
            }
            
            if (json.success) {
                $('#content').prepend('<div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> ' + json.success + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
                
                // Перезагружаем страницу через 1 секунду
                setTimeout(function() {
                    location.reload();
                }, 1000);
            }
        },
        error: function() {
            $('#content').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_ajax }} <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
        },
        complete: function() {
            button.prop('disabled', false).html(originalText);
        }
    });
});

// Просмотр информации о модуле
function viewModuleInfo(code) {
    $.ajax({
        url: 'index.php?route=extension/module/gdt_update_server/info&user_token={{ user_token }}',
        type: 'POST',
        data: {
            code: code
        },
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                alert(json.error);
            } else {
                var html = '<table class="table table-bordered">';
                html += '<tr><td><strong>{{ column_name }}:</strong></td><td>' + json.name + '</td></tr>';
                html += '<tr><td><strong>{{ column_code }}:</strong></td><td>' + json.code + '</td></tr>';
                html += '<tr><td><strong>{{ column_version }}:</strong></td><td>' + json.version + '</td></tr>';
                html += '<tr><td><strong>{{ column_author }}:</strong></td><td>' + (json.author || '-') + '</td></tr>';
                html += '<tr><td><strong>{{ column_description }}:</strong></td><td>' + (json.description || '-') + '</td></tr>';
                html += '<tr><td><strong>{{ column_upload_date }}:</strong></td><td>' + json.upload_date + '</td></tr>';
                html += '</table>';
                
                $('#module-info-content').html(html);
                $('#modal-module-info').modal('show');
            }
        },
        error: function() {
            alert('{{ error_ajax }}');
        }
    });
}

// Обновление модуля
function updateModule(code) {
    if (confirm('{{ text_confirm_update }}')) {
        // Здесь будет логика обновления модуля
        alert('{{ text_update_not_implemented }}');
    }
}

// Удаление модуля
function deleteModule(code) {
    if (confirm('{{ text_confirm_delete }}')) {
        $.ajax({
            url: 'index.php?route=extension/module/gdt_update_server/delete&user_token={{ user_token }}',
            type: 'POST',
            data: {
                code: code
            },
            dataType: 'json',
            success: function(json) {
                if (json.error) {
                    $('#content').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json.error + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
                }
                
                if (json.success) {
                    $('#module-row-' + code).fadeOut(function() {
                        $(this).remove();
                        
                        // Если больше нет модулей, показываем пустое состояние
                        if ($('tbody tr').length === 0) {
                            location.reload();
                        }
                    });
                }
            },
            error: function() {
                $('#content').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_ajax }} <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
            }
        });
    }
}

// Сканирование модулей в файловой системе
$('#button-scan').click(function() {
    var button = $(this);
    button.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Сканирование...');
    
    $.ajax({
        url: 'index.php?route=extension/module/gdt_update_server/scan&user_token={{ user_token }}',
        type: 'POST',
        dataType: 'json',
        success: function(json) {
            button.prop('disabled', false).html('<i class="fa fa-search"></i> Сканировать модули');
            
            if (json.error) {
                $('#content').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json.error + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
            }
            
            if (json.success && json.modules) {
                var html = '<div class="table-responsive"><table class="table table-striped">';
                html += '<thead><tr><th>Код</th><th>Название</th><th>Версия</th><th>Автор</th><th>Путь</th></tr></thead><tbody>';
                
                if (json.modules.length > 0) {
                    $.each(json.modules, function(index, module) {
                        html += '<tr>';
                        html += '<td>' + module.code + '</td>';
                        html += '<td>' + module.name + '</td>';
                        html += '<td>' + module.version + '</td>';
                        html += '<td>' + module.author + '</td>';
                        html += '<td><small>' + module.path + '</small></td>';
                        html += '</tr>';
                    });
                } else {
                    html += '<tr><td colspan="5" class="text-center">Модули с файлами opencart-module.json не найдены</td></tr>';
                }
                
                html += '</tbody></table></div>';
                $('#scanned-modules').html(html);
                $('#sync-results').show();
            }
        },
        error: function() {
            button.prop('disabled', false).html('<i class="fa fa-search"></i> Сканировать модули');
            $('#content').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> Ошибка при сканировании <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
        }
    });
});

// Синхронизация всех модулей
$('#button-sync').click(function() {
    if (!confirm('Синхронизировать все модули из файловой системы с базой данных?')) {
        return;
    }
    
    var button = $(this);
    button.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Синхронизация...');
    
    $.ajax({
        url: 'index.php?route=extension/module/gdt_update_server/sync&user_token={{ user_token }}',
        type: 'POST',
        dataType: 'json',
        success: function(json) {
            button.prop('disabled', false).html('<i class="fa fa-refresh"></i> Синхронизировать все');
            
            if (json.error) {
                $('#content').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json.error + ' <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
            }
            
            if (json.success) {
                $('#content').prepend('<div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> ' + json.success + ' (синхронизировано: ' + json.synced_modules + ' модулей) <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
                
                // Перезагружаем страницу для обновления списка модулей
                setTimeout(function() {
                    location.reload();
                }, 2000);
            }
        },
        error: function() {
            button.prop('disabled', false).html('<i class="fa fa-refresh"></i> Синхронизировать все');
            $('#content').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> Ошибка при синхронизации <button type="button" class="close" data-dismiss="alert">&times;</button></div>');
        }
    });
});

// Инициализация подсказок
$('[data-toggle="tooltip"]').tooltip();
</script>

{{ footer }}
