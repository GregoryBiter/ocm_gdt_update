{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" id="button-settings" class="btn btn-info"><i class="fa fa-cog"></i> Настройки</button>
        <button type="button" id="button-check" data-loading-text="Загрузка..." class="btn btn-info"><i class="fa fa-refresh"></i> Проверить обновления</button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="Отмена" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>GDT Module Updater</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <!-- Сообщения -->
    <div id="alert-container"></div>
    
    <!-- Модальное окно настроек -->
    <div class="modal fade" id="modal-settings" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title">Настройки модуля</h4>
          </div>
          <div class="modal-body">
            <form id="form-settings">
              <div class="form-group">
                <label for="input-server">Сервер обновлений</label>
                <input type="text" name="module_gdt_updater_server" id="input-server" class="form-control" placeholder="URL сервера обновлений" />
              </div>
              <div class="form-group">
                <label for="input-client-id">Client ID</label>
                <input type="text" name="module_gdt_updater_client_id" id="input-client-id" class="form-control" placeholder="Идентификатор клиента" />
                <small class="help-block">Уникальный идентификатор клиента для аутентификации</small>
              </div>
              <div class="form-group">
                <label for="input-api-key">API ключ</label>
                <input type="text" name="module_gdt_updater_api_key" id="input-api-key" class="form-control" placeholder="API ключ" />
                <small class="help-block">Секретный ключ для доступа к серверу обновлений</small>
              </div>
              <div class="form-group">
                <label for="input-status">Статус</label>
                <select name="module_gdt_updater_status" id="input-status" class="form-control">
                  <option value="1">Включен</option>
                  <option value="0">Отключен</option>
                </select>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Отмена</button>
            <button type="button" class="btn btn-primary" id="button-save-settings">Сохранить</button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Список модулей -->
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-list"></i> Установленные модули</h3>
      </div>
      <div class="panel-body">
        <div id="modules-loading" class="text-center" style="padding: 20px;">
          <i class="fa fa-spinner fa-spin fa-2x"></i>
          <p>Загрузка модулей...</p>
        </div>
        <div id="modules-container" style="display: none;">
          <!-- Контент будет загружен через AJAX -->
        </div>
        <div id="update-results"></div>
      </div>
    </div>
  </div>
</div>

<script type="text/javascript"><!--
// URL-адреса для AJAX запросов
var ajaxUrls = {
    settings: '{{ settings_url }}',
    saveSettings: '{{ save_settings_url }}',
    modules: '{{ modules_url }}',
    checkUpdates: '{{ check_updates }}'
};

var userToken = '{{ user_token }}';

// Функция для отображения уведомлений
function showAlert(type, message) {
    var alertClass = 'alert-' + type;
    var iconClass = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    
    var alert = '<div class="alert ' + alertClass + ' alert-dismissible">';
    alert += '<i class="fa ' + iconClass + '"></i> ' + message;
    alert += '<button type="button" class="close" data-dismiss="alert">&times;</button>';
    alert += '</div>';
    
    $('#alert-container').html(alert);
    
    // Автоматически скрыть через 5 секунд
    setTimeout(function() {
        $('#alert-container .alert').alert('close');
    }, 5000);
}

// Загрузка настроек
function loadSettings() {
    $.ajax({
        url: ajaxUrls.settings,
        dataType: 'json',
        success: function(json) {
            $('#input-server').val(json.module_gdt_updater_server || '');
            $('#input-client-id').val(json.module_gdt_updater_client_id || '');
            $('#input-api-key').val(json.module_gdt_updater_api_key || '');
            $('#input-status').val(json.module_gdt_updater_status || '0');
        },
        error: function() {
            showAlert('danger', 'Ошибка загрузки настроек');
        }
    });
}

// Сохранение настроек
function saveSettings() {
    var formData = $('#form-settings').serialize();
    
    $.ajax({
        url: ajaxUrls.saveSettings,
        type: 'POST',
        data: formData,
        dataType: 'json',
        success: function(json) {
            if (json.success) {
                showAlert('success', json.success);
                $('#modal-settings').modal('hide');
                loadModules(); // Перезагружаем модули после сохранения настроек
            } else if (json.error) {
                showAlert('danger', json.error);
            }
        },
        error: function() {
            showAlert('danger', 'Ошибка сохранения настроек');
        }
    });
}

// Загрузка модулей
function loadModules() {
    $('#modules-loading').show();
    $('#modules-container').hide();
    
    $.ajax({
        url: ajaxUrls.modules,
        dataType: 'json',
        success: function(json) {
            $('#modules-loading').hide();
            
            if (json.error) {
                $('#modules-container').html('<div class="alert alert-info"><i class="fa fa-info-circle"></i> ' + json.error + '</div>');
            } else if (json.modules && json.modules.length > 0) {
                var html = '<table class="table table-bordered table-hover">';
                html += '<thead>';
                html += '<tr>';
                html += '<td>Название</td>';
                html += '<td>Описание</td>';
                html += '<td>Текущая версия</td>';
                html += '<td>Новая версия</td>';
                html += '<td class="text-right">Действия</td>';
                html += '</tr>';
                html += '</thead>';
                html += '<tbody>';
                
                for (var i = 0; i < json.modules.length; i++) {
                    var module = json.modules[i];
                    html += '<tr>';
                    html += '<td>' + module.name + '</td>';
                    html += '<td>' + module.description + '</td>';
                    html += '<td>' + module.version + '</td>';
                    html += '<td>';
                    if (module.has_update) {
                        html += module.new_version;
                    } else {
                        html += '<span class="text-success">Актуальная</span>';
                    }
                    html += '</td>';
                    html += '<td class="text-right">';
                    if (module.has_update) {
                        html += '<a href="' + module.update_url + '" class="btn btn-primary btn-sm update-module" data-code="' + module.code + '"><i class="fa fa-refresh"></i> Обновить</a> ';
                    } else {
                        html += '<button class="btn btn-default btn-sm" disabled="disabled"><i class="fa fa-check"></i> Актуально</button> ';
                    }
                    if (module.has_backup) {
                        html += '<a href="' + module.restore_url + '" class="btn btn-warning btn-sm restore-module" data-code="' + module.code + '"><i class="fa fa-undo"></i> Восстановить</a>';
                    }
                    html += '</td>';
                    html += '</tr>';
                }
                
                html += '</tbody>';
                html += '</table>';
                
                $('#modules-container').html(html);
                
                // Показываем предупреждения об ошибках, если есть
                if (json.error_curl) {
                    showAlert('danger', json.error_curl);
                }
                if (json.error_http) {
                    showAlert('danger', json.error_http);
                }
            } else {
                $('#modules-container').html('<div class="alert alert-info"><i class="fa fa-info-circle"></i> Модули не найдены</div>');
            }
            
            $('#modules-container').show();
        },
        error: function() {
            $('#modules-loading').hide();
            $('#modules-container').html('<div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> Ошибка загрузки модулей</div>').show();
        }
    });
}

// Обработчики событий
$(document).ready(function() {
    // Загружаем модули при загрузке страницы
    loadModules();
    
    // Кнопка настроек
    $('#button-settings').on('click', function() {
        loadSettings();
        $('#modal-settings').modal('show');
    });
    
    // Сохранение настроек
    $('#button-save-settings').on('click', function() {
        saveSettings();
    });
    
    // Проверка обновлений
    $('#button-check').on('click', function() {
        var button = $(this);
        
        $.ajax({
            url: ajaxUrls.checkUpdates,
            dataType: 'json',
            beforeSend: function() {
                button.button('loading');
            },
            complete: function() {
                button.button('reset');
            },
            success: function(json) {
                if (json.error) {
                    showAlert('danger', json.error);
                } else if (json.success) {
                    showAlert('success', json.success);
                    // Перезагружаем модули
                    setTimeout(function() {
                        loadModules();
                    }, 1000);
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                showAlert('danger', 'Ошибка проверки обновлений: ' + thrownError);
            }
        });
    });
    
    // Обновление модуля
    $(document).on('click', '.update-module', function(e) {
        e.preventDefault();
        
        var element = this;
        var url = $(element).attr('href');
        
        $.ajax({
            url: url,
            dataType: 'json',
            beforeSend: function() {
                $(element).html('<i class="fa fa-spinner fa-spin"></i> Обновление...').prop('disabled', true);
            },
            success: function(json) {
                if (json.error) {
                    showAlert('danger', json.error);
                    $(element).html('<i class="fa fa-refresh"></i> Обновить').prop('disabled', false);
                } else if (json.success) {
                    showAlert('success', json.success);
                    // Перезагружаем модули после успешного обновления
                    setTimeout(function() {
                        loadModules();
                    }, 2000);
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                showAlert('danger', 'Ошибка обновления: ' + thrownError);
                $(element).html('<i class="fa fa-refresh"></i> Обновить').prop('disabled', false);
            }
        });
    });
    
    // Восстановление модуля
    $(document).on('click', '.restore-module', function(e) {
        e.preventDefault();
        
        if (!confirm('Вы уверены, что хотите восстановить модуль из резервной копии?')) {
            return false;
        }
        
        var element = this;
        var url = $(element).attr('href');
        
        $.ajax({
            url: url,
            dataType: 'json',
            beforeSend: function() {
                $(element).html('<i class="fa fa-spinner fa-spin"></i> Восстановление...').prop('disabled', true);
            },
            success: function(json) {
                if (json.error) {
                    showAlert('danger', json.error);
                    $(element).html('<i class="fa fa-undo"></i> Восстановить').prop('disabled', false);
                } else if (json.success) {
                    showAlert('success', json.success);
                    // Перезагружаем модули после успешного восстановления
                    setTimeout(function() {
                        loadModules();
                    }, 2000);
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                showAlert('danger', 'Ошибка восстановления: ' + thrownError);
                $(element).html('<i class="fa fa-undo"></i> Восстановить').prop('disabled', false);
            }
        });
    });
});
//--></script>
{{ footer }}
