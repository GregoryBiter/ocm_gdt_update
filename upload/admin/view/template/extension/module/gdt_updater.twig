{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" id="button-install-modules" class="btn btn-success"><i class="fa fa-download"></i> {{ button_install }}</button>
        <button type="button" id="button-delete-selected" class="btn btn-danger" disabled><i class="fa fa-trash"></i> {{ button_delete_selected }}</button>
        <button type="button" id="button-settings" class="btn btn-info"><i class="fa fa-cog"></i> {{ button_settings }}</button>
        <button type="button" id="button-check" data-loading-text="{{ text_loading }}" class="btn btn-info"><i class="fa fa-refresh"></i> {{ button_check }}</button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <!-- Сообщения -->
    <div id="alert-container"></div>
    
    <!-- Модальное окно настроек -->
    <div class="modal fade" id="modal-settings" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title">{{ text_settings_title }}</h4>
          </div>
          <div class="modal-body">
            <form id="form-settings">
              <div class="form-group">
                <label for="input-server">{{ entry_server }}</label>
                <input type="text" name="module_gdt_updater_server" id="input-server" class="form-control" placeholder="{{ entry_server }}" />
              </div>
              <div class="form-group">
                <label for="input-api-key">{{ entry_api_key }}</label>
                <input type="text" name="module_gdt_updater_api_key" id="input-api-key" class="form-control" placeholder="{{ entry_api_key }}" />
                <small class="help-block">{{ help_api_key }}</small>
              </div>
              <div class="form-group">
                <label for="input-status">{{ entry_status }}</label>
                <select name="module_gdt_updater_status" id="input-status" class="form-control">
                  <option value="1">{{ text_enabled }}</option>
                  <option value="0">{{ text_disabled }}</option>
                </select>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">{{ button_cancel }}</button>
            <button type="button" class="btn btn-primary" id="button-save-settings">{{ button_save }}</button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Модальное окно установки модулей -->
    <div class="modal fade" id="modal-install-modules" tabindex="-1" role="dialog">
      <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title">{{ button_install }}</h4>
          </div>
          <div class="modal-body">
            <div id="install-modules-content">
              <div class="text-center">
                <i class="fa fa-spinner fa-spin fa-2x"></i>
                <p>{{ text_loading }}</p>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">{{ button_close }}</button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Модальное окно подтверждения удаления -->
    <div class="modal fade" id="modal-delete-confirm" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title"><i class="fa fa-warning text-danger"></i> {{ button_confirm }}</h4>
          </div>
          <div class="modal-body">
            <div class="alert alert-warning">
              <i class="fa fa-exclamation-triangle"></i>
              <strong>{{ text_warning }}</strong> {{ text_delete_warning }}
            </div>
            <p id="delete-message">{{ text_delete_confirm }}</p>
            <div id="modules-to-delete" style="display: none;">
              <strong>{{ text_modules_to_delete }}</strong>
              <ul id="delete-modules-list"></ul>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">{{ button_cancel }}</button>
            <button type="button" class="btn btn-danger" id="button-confirm-delete">
              <i class="fa fa-trash"></i> {{ button_delete }}
            </button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Список модулей -->
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-th-large"></i> {{ text_installed_modules }}</h3>
      </div>
      <div class="panel-body">
        {% if modules is empty %}
          <div class="no-modules">
            <i class="fa fa-puzzle-piece"></i>
            <h3>{{ text_no_modules_found }}</h3>
            <p>{{ text_no_modules_desc }}</p>
          </div>
        {% else %}
          <div class="modules-list">
            <div class="modules-list-header">
              <div class="select-all-container">
                <input type="checkbox" id="select-all-modules" class="module-checkbox">
                <label for="select-all-modules">{{ text_select_all }}</label>
              </div>
              <i class="fa fa-th-list"></i>{{ text_module_management }} ({{ modules|length }})
            </div>
            
            {% for module in modules %}
              <div class="module-item {{ module.has_update ? 'has-update' : 'up-to-date' }}" data-code="{{ module.code }}">
                
                <!-- Чекбокс для выбора модуля -->
                <div class="module-select">
                  <input type="checkbox" class="module-checkbox" data-code="{{ module.code }}" id="module-{{ module.code }}">
                </div>
                
                {% if module.has_update %}
                  <div class="update-indicator">{{ text_new_version_available }}</div>
                {% endif %}
                
                <!-- Колонка 1: Название + ссылки действий -->
                <div class="module-column-1">
                  <h3 class="module-title">
                    <i class="fa fa-puzzle-piece"></i>{{ module.name }}
                  </h3>
                  
                  <!-- Ссылки действий -->
                  <div class="module-actions-links">
                    
                    <!-- Ссылка на настройки (если есть) -->
                    {% if module.settings_url %}
                      <a href="{{ module.settings_url }}" class="action-link settings-link">
                        <i class="fa fa-cog"></i> {{ button_settings }}
                      </a>
                      <span class="action-separator">|</span>
                    {% endif %}
                    
                    <!-- Ссылка на обновление или актуально -->
                    {% if module.has_update %}
                      <a href="#" class="action-link update-link update-module" data-url="{{ module.update_url }}" data-code="{{ module.code }}">
                        <i class="fa fa-download"></i> {{ text_update }} {{ text_to }} {{ module.new_version }}
                      </a>
                    {% else %}
                      <span class="action-link" style="color: #28a745;">
                        <i class="fa fa-check"></i> {{ text_status_actual }}
                      </span>
                    {% endif %}
                    
                    <!-- Кнопка удаления -->
                    {% if module.delete_url %}
                      <span class="action-separator">|</span>
                      <a href="#" class="action-link delete-link delete-module" data-url="{{ module.delete_url }}" data-code="{{ module.code }}" data-name="{{ module.name }}">
                        <i class="fa fa-trash text-danger"></i> {{ button_delete }}
                      </a>
                    {% endif %}
                    
                  </div>
                </div>
                
                <!-- Колонка 2: Описание, версия, автор -->
                <div class="module-column-2">
                  <p class="module-description">{{ module.description }}</p>
                  
                  <div class="module-meta">
                    <!-- Версия и код в одной строке -->
                    <div class="meta-item">
                      <span class="meta-label">{{ text_version }}:</span>
                      <span class="version-current">{{ module.version }}</span>
                      {% if module.has_update %}
                        → <span class="version-new">{{ module.new_version }}</span>
                      {% endif %}
                      | <span class="meta-label">{{ text_code }}:</span> <span>{{ module.code }}</span>
                    </div>
                    
                    <!-- Автор -->
                    {% if module.author %}
                      <div class="meta-item">
                        <span class="meta-label">{{ text_author }}:</span>
                        {% if module.author_url %}
                          <a href="{{ module.author_url }}" class="module-author" target="_blank">{{ module.author }}</a>
                        {% else %}
                          <span>{{ module.author }}</span>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                </div>
                
                <!-- Колонка 3: Автообновления -->
                <div class="module-column-3">
                  <div class="auto-update-section">
                    <label class="auto-update-label">{{ text_auto_update }}</label>
                    <a href="#" class="auto-update-link" data-code="{{ module.code }}" data-current="{{ module.auto_update ? '1' : '0' }}">
                      {% if module.auto_update %}
                        <i class="fa fa-toggle-on"></i> {{ text_on }}
                      {% else %}
                        <i class="fa fa-toggle-off"></i> {{ text_off }}
                      {% endif %}
                    </a>
                  </div>
                </div>
                
              </div>
            {% endfor %}
            
          </div>
        {% endif %}
        <div id="update-results"></div>
      </div>
    </div>
  </div>
</div>


<script type="text/javascript"><!--
// URL-адреса для AJAX запросов
var ajaxUrls = {
    settings: '{{ settings_url }}',
    saveSettings: '{{ save_settings_url }}',
    checkUpdates: '{{ check_updates }}',
    toggleAutoUpdate: '{{ toggle_auto_update_url }}',
    deleteMultiple: '{{ delete_multiple_url }}',
    getAvailableModules: '{{ get_available_modules_url }}',
    installModule: '{{ install_module_url }}'
};

var userToken = '{{ user_token }}';

var textMsg = {
    loading: '{{ text_loading|escape("js") }}',
    statusActual: '{{ text_status_actual|escape("js") }}',
    buttonInstall: '{{ button_install|escape("js") }}',
    buttonConfirm: '{{ button_confirm|escape("js") }}',
    on: '{{ text_on|escape("js") }}',
    off: '{{ text_off|escape("js") }}',
    confirmSave: '{{ text_confirm_save|escape("js") }}',
    buttonDeleteSelected: '{{ button_delete_selected|escape("js") }}',
    deleteMultipleConfirm: '{{ text_delete_multiple_confirm|escape("js") }}',
    deleteConfirm: '{{ text_delete_confirm|escape("js") }}',
    deleting: '{{ text_deleting|escape("js") }}',
    massDeleting: '{{ text_mass_deleting|escape("js") }}',
    moduleManagement: '{{ text_module_management|escape("js") }}',
    noModulesFound: '{{ text_no_modules_found|escape("js") }}',
    noModulesDesc: '{{ text_no_modules_desc|escape("js") }}',
    author: '{{ text_author|escape("js") }}',
    selectAll: '{{ text_select_all|escape("js") }}',
    search: '{{ text_search|escape("js") }}'
};

var errorMsg = {
    occurred: '{{ error_occurred|escape("js") }}',
    save: '{{ error_save|escape("js") }}',
    check: '{{ error_check|escape("js") }}',
    server: '{{ error_server|escape("js") }}',
    code: '{{ error_code|escape("js") }}',
    massDelete: '{{ error_mass_delete|escape("js") }}'
};
//--></script>
{{ footer }}
