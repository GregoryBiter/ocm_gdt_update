{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" id="button-install-modules" class="btn btn-success"><i class="fa fa-download"></i> Установить модули</button>
        <button type="button" id="button-delete-selected" class="btn btn-danger" disabled><i class="fa fa-trash"></i> Удалить выбранные</button>
        <button type="button" id="button-settings" class="btn btn-info"><i class="fa fa-cog"></i> Настройки</button>
        <button type="button" id="button-check" data-loading-text="Загрузка..." class="btn btn-info"><i class="fa fa-refresh"></i> Проверить обновления</button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="Отмена" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>GDT Module Updater</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    <!-- Сообщения -->
    <div id="alert-container"></div>
    
    <!-- Модальное окно настроек -->
    <div class="modal fade" id="modal-settings" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title">Настройки модуля</h4>
          </div>
          <div class="modal-body">
            <form id="form-settings">
              <div class="form-group">
                <label for="input-server">Сервер обновлений</label>
                <input type="text" name="module_gdt_updater_server" id="input-server" class="form-control" placeholder="URL сервера обновлений" />
              </div>
              <div class="form-group">
                <label for="input-api-key">API ключ</label>
                <input type="text" name="module_gdt_updater_api_key" id="input-api-key" class="form-control" placeholder="API ключ" />
                <small class="help-block">Секретный ключ для доступа к серверу обновлений</small>
              </div>
              <div class="form-group">
                <label for="input-status">Статус</label>
                <select name="module_gdt_updater_status" id="input-status" class="form-control">
                  <option value="1">Включен</option>
                  <option value="0">Отключен</option>
                </select>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Отмена</button>
            <button type="button" class="btn btn-primary" id="button-save-settings">Сохранить</button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Модальное окно установки модулей -->
    <div class="modal fade" id="modal-install-modules" tabindex="-1" role="dialog">
      <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title">Установка модулей</h4>
          </div>
          <div class="modal-body">
            <div id="install-modules-content">
              <div class="text-center">
                <i class="fa fa-spinner fa-spin fa-2x"></i>
                <p>Загрузка доступных модулей...</p>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Закрыть</button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Модальное окно подтверждения удаления -->
    <div class="modal fade" id="modal-delete-confirm" tabindex="-1" role="dialog">
      <div class="modal-dialog" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
            <h4 class="modal-title"><i class="fa fa-warning text-danger"></i> Подтверждение удаления</h4>
          </div>
          <div class="modal-body">
            <div class="alert alert-warning">
              <i class="fa fa-exclamation-triangle"></i>
              <strong>Внимание!</strong> Удаление модуля необратимо.
            </div>
            <p id="delete-message">Вы уверены, что хотите удалить этот модуль? Все файлы модуля будут удалены!</p>
            <div id="modules-to-delete" style="display: none;">
              <strong>Модули для удаления:</strong>
              <ul id="delete-modules-list"></ul>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-default" data-dismiss="modal">Отмена</button>
            <button type="button" class="btn btn-danger" id="button-confirm-delete">
              <i class="fa fa-trash"></i> Удалить
            </button>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Список модулей -->
    <div class="panel panel-default pw-panel">
      <div class="panel-heading pw-panel-heading">
        <h3 class="panel-title"><i class="fa fa-plug"></i> Установленные модули</h3>
        <div class="pw-search">
           <input type="text" class="form-control" id="pw-filter-modules" placeholder="Поиск установленных модулей...">
        </div>
      </div>
      <div class="panel-body pw-panel-body">
        {% if modules is empty %}
          <div class="pw-no-modules">
            <i class="fa fa-inbox"></i>
            <h3>У вас пока нет установленных модулей</h3>
            <p>Перейдите в каталог, чтобы найти и установить новые модули.</p>
            <a href="{{ install_modules_url }}" class="btn btn-primary">Посмотреть каталог</a>
          </div>
        {% else %}
          <table class="table pw-modules-table">
            <thead>
              <tr>
                <th class="col-cb"><input type="checkbox" id="select-all-modules" class="module-checkbox"></th>
                <th class="col-name">Модуль</th>
                <th class="col-desc">Описание</th>
                <th class="col-auto">Автообновление</th>
              </tr>
            </thead>
            <tbody id="modules-tbody">
            {% for module in modules %}
              <tr class="pw-module-row {{ module.has_update ? 'has-update' : '' }}" data-code="{{ module.code }}">
                <td class="col-cb">
                  <input type="checkbox" class="module-checkbox" data-code="{{ module.code }}" id="module-{{ module.code }}">
                </td>
                
                <td class="col-name">
                  <div class="pw-module-name-wrap">
                    <h3 class="pw-module-title">{{ module.name }}</h3>
                  </div>
                  
                  <div class="pw-row-actions">
                    {% if module.settings_url %}
                      <span class="settings"><a href="{{ module.settings_url }}">Настройки</a> | </span>
                    {% endif %}
                    
                    {% if module.has_update %}
                      <span class="update"><a href="#" class="update-module" data-url="{{ module.update_url }}" data-code="{{ module.code }}" style="color: #d63638;">Обновить сейчас</a> | </span>
                    {% endif %}
                    
                    {% if module.delete_url %}
                      <span class="delete"><a href="#" class="delete-module" data-url="{{ module.delete_url }}" data-code="{{ module.code }}" data-name="{{ module.name }}" style="color: #b32d2e;">Удалить</a></span>
                    {% endif %}
                  </div>
                </td>
                
                <td class="col-desc">
                  <div class="pw-module-description">
                    <p>{{ module.description }}</p>
                  </div>
                  <div class="pw-module-meta">
                    <span class="pw-version">Версия {{ module.version }}</span>
                    {% if module.author %}
                      | <span class="pw-author">Автор: <a href="{{ module.author_url }}" target="_blank">{{ module.author }}</a></span>
                    {% endif %}
                    {% if module.has_update %}
                      <div class="pw-update-notice">
                        <strong>Доступна новая версия: {{ module.new_version }}</strong>. <a href="#" class="update-module" data-url="{{ module.update_url }}" data-code="{{ module.code }}">Обновите сейчас</a>.
                      </div>
                    {% endif %}
                  </div>
                </td>
                
                <td class="col-auto">
                  <a href="#" class="auto-update-link" data-code="{{ module.code }}" data-current="{{ module.auto_update ? '1' : '0' }}">
                      {% if module.auto_update %}
                        <span style="color:#0071a1">Включено</span>
                      {% else %}
                        <span style="color:#2271b1">Включить</span>
                      {% endif %}
                    </a>
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        {% endif %}
        <div id="update-results"></div>
      </div>
    </div>
  </div>
</div>

<style>
/* WordPress-подобные стили для списка модулей */
.pw-panel { border: none; box-shadow: 0 1px 1px rgba(0,0,0,.04); border-radius: 4px; }
.pw-panel-heading { background: #fff !important; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ccd0d4; }
.pw-panel-heading .panel-title { font-size: 18px; font-weight: 400; color: #1d2327; }
.pw-panel-body { padding: 0 !important; }
.pw-table { margin-bottom: 0; border-collapse: collapse; width: 100%; }

.pw-modules-table thead th {
    border-bottom: 1px solid #ccd0d4 !important;
    color: #2c3338;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
    padding: 8px 10px;
}
.pw-modules-table tbody tr {
    border-top: 1px solid #c3c4c7;
    background-color: #fff;
}
.pw-modules-table tbody tr:nth-last-child(1) { border-bottom: 1px solid #c3c4c7; }
.pw-modules-table tbody tr.has-update { background-color: #fcf0f1; }
.pw-modules-table tbody td { padding: 15px 10px; vertical-align: top; border-top: none; }

/* Columns */
.col-cb { width: 40px; text-align: center; }
.col-name { width: 25%; }
.col-desc { width: 55%; }
.col-auto { width: 15%; }

/* Typography */
.pw-module-title { font-size: 14px; font-weight: 600; line-height: 1.5; margin: 0 0 5px 0; color: #2271b1; }
.pw-row-actions { visibility: hidden; font-size: 13px; color: #ddd; padding: 2px 0 0; }
.pw-module-row:hover .pw-row-actions { visibility: visible; }
.pw-row-actions a { color: #2271b1; text-decoration: none; }
.pw-row-actions a:hover { color: #135e96; text-decoration: underline; }

.pw-module-description p { margin: 0 0 8px 0; font-size: 13px; line-height: 1.5; color: #3c434a; }
.pw-module-meta { font-size: 13px; color: #a7aaad; }
.pw-author a { color: #3c434a; text-decoration: none; }
.pw-author a:hover { color: #2271b1; }

.pw-update-notice {
    background-color: #fcf0f1;
    border-left: 4px solid #d63638;
    padding: 10px 15px;
    margin-top: 10px;
    font-size: 13px;
    color: #1d2327;
}

.pw-no-modules { text-align: center; padding: 60px 20px; }
.pw-no-modules i { font-size: 48px; color: #c3c4c7; margin-bottom: 15px; }

/* Buttons & Links */
.auto-update-link { display: inline-block; padding: 4px 0; text-decoration: none; font-size: 13px; }
.auto-update-link:hover { text-decoration: underline; }

/* Search bar */
.pw-search { max-width: 250px; }
.pw-search input { height: 32px; font-size: 13px; border-radius: 4px; border: 1px solid #8c8f94; }

@media (max-width: 768px) {
    .pw-modules-table thead { display: none; }
    .pw-modules-table tbody td { display: block; width: 100%; border: none !important; }
    .pw-row-actions { visibility: visible; }
}
</style>

<script type="text/javascript"><!--
// URL-адреса для AJAX запросов
var ajaxUrls = {
    settings: '{{ settings_url }}',
    saveSettings: '{{ save_settings_url }}',
    checkUpdates: '{{ check_updates }}',
    toggleAutoUpdate: '{{ toggle_auto_update_url }}',
    deleteMultiple: '{{ delete_multiple_url }}',
    getAvailableModules: '{{ get_available_modules_url }}',
    installModule: '{{ install_module_url }}'
};

var userToken = '{{ user_token }}';

// Функция для отображения уведомлений
function showAlert(type, message) {
    var alertClass = 'alert-' + type;
    var iconClass = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    
    var alert = '<div class="alert ' + alertClass + ' alert-dismissible">';
    alert += '<i class="fa ' + iconClass + '"></i> ' + message;
    alert += '<button type="button" class="close" data-dismiss="alert">&times;</button>';
    alert += '</div>';
    
    $('#alert-container').html(alert);
    
    // Автоматически скрыть через 5 секунд
    setTimeout(function() {
        $('#alert-container .alert').alert('close');
    }, 5000);
}

// Загрузка настроек
function loadSettings() {
    $.ajax({
        url: ajaxUrls.settings,
        dataType: 'json',
        success: function(json) {
            $('#input-server').val(json.module_gdt_updater_server || '');
            $('#input-api-key').val(json.module_gdt_updater_api_key || '');
            $('#input-status').val(json.module_gdt_updater_status || '0');
        },
        error: function() {
            showAlert('danger', 'Ошибка загрузки настроек');
        }
    });
}

// Сохранение настроек
function saveSettings() {
    var formData = $('#form-settings').serialize();
    
    $.ajax({
        url: ajaxUrls.saveSettings,
        type: 'POST',
        data: formData,
        dataType: 'json',
        success: function(json) {
            if (json.success) {
                showAlert('success', json.success);
                $('#modal-settings').modal('hide');
                // Перезагружаем страницу после сохранения настроек
                setTimeout(function() {
                    location.reload();
                }, 1000);
            } else if (json.error) {
                showAlert('danger', json.error);
            }
        },
        error: function() {
            showAlert('danger', 'Ошибка сохранения настроек');
        }
    });
}

// Загрузка доступных модулей
function loadAvailableModules() {
    $.ajax({
        url: ajaxUrls.getAvailableModules,
        dataType: 'json',
        success: function(json) {
            if (json.error) {
                $('#install-modules-content').html('<div class="no-available-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка загрузки</h3><p>' + json.error + '</p></div>');
            } else if (json.modules) {
                renderAvailableModules(json.modules);
            }
        },
        error: function() {
            $('#install-modules-content').html('<div class="no-available-modules"><i class="fa fa-exclamation-triangle"></i><h3>Ошибка подключения</h3><p>Не удалось загрузить список модулей с сервера</p></div>');
        }
    });
}

// Отображение доступных модулей
function renderAvailableModules(modules) {
    var html = '';
    
    if (modules.length === 0) {
        html = '<div class="no-available-modules"><i class="fa fa-puzzle-piece"></i><h3>Модули не найдены</h3><p>На сервере нет доступных модулей для установки</p></div>';
    } else {
        // Добавляем поиск и фильтры
        html += '<div class="install-modules-search">';
        html += '<input type="text" id="modules-search" placeholder="Поиск модулей..." />';
        html += '</div>';
        
        html += '<div class="install-modules-filter">';
        html += '<button class="filter-btn active" data-filter="all">Все (' + modules.length + ')</button>';
        html += '<button class="filter-btn" data-filter="new">Новые</button>';
        html += '<button class="filter-btn" data-filter="popular">Популярные</button>';
        html += '</div>';
        
        html += '<div class="install-modules-stats">';
        html += '<span>Найдено модулей: <strong>' + modules.length + '</strong></span>';
        html += '<span>Доступно для установки</span>';
        html += '</div>';
        
        html += '<div class="install-modules-grid">';
        
        modules.forEach(function(module) {
            html += '<div class="install-module-card" data-module="' + module.code + '">';
            
            html += '<div class="install-module-header">';
            html += '<h3 class="install-module-title">' + module.name + '</h3>';
            html += '<span class="install-module-version">v' + module.version + '</span>';
            html += '</div>';
            
            html += '<div class="install-module-description">' + module.description + '</div>';
            
            html += '<div class="install-module-meta">';
            if (module.author) {
                html += '<div class="install-module-meta-item">';
                html += '<span class="install-module-meta-label">Автор:</span>';
                html += '<span>' + module.author + '</span>';
                html += '</div>';
            }
            if (module.size) {
                html += '<div class="install-module-meta-item">';
                html += '<span class="install-module-meta-label">Размер:</span>';
                html += '<span>' + module.size + '</span>';
                html += '</div>';
            }
            if (module.downloads) {
                html += '<div class="install-module-meta-item">';
                html += '<span class="install-module-meta-label">Загрузок:</span>';
                html += '<span>' + module.downloads + '</span>';
                html += '</div>';
            }
            html += '</div>';
            
            html += '<div class="install-module-actions">';
            if (module.is_installed) {
                html += '<span class="install-module-installed"><i class="fa fa-check"></i> Установлен</span>';
            } else {
                html += '<button class="install-module-btn" data-code="' + module.code + '" data-url="' + module.download_url + '">';
                html += '<i class="fa fa-download"></i> Установить';
                html += '</button>';
            }
            
            if (module.demo_url) {
                html += '<a href="' + module.demo_url + '" target="_blank" class="install-module-link">Демо</a>';
            }
            html += '</div>';
            
            html += '</div>';
        });
        
        html += '</div>';
    }
    
    $('#install-modules-content').html(html);
}

// Установка модуля
function installModule(moduleCode, downloadUrl, buttonElement) {
    var originalText = $(buttonElement).html();
    
    $.ajax({
        url: ajaxUrls.installModule,
        type: 'POST',
        data: {
            module_code: moduleCode,
            download_url: downloadUrl,
            user_token: userToken
        },
        dataType: 'json',
        beforeSend: function() {
            $(buttonElement).prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Установка...');
        },
        success: function(json) {
            if (json.success) {
                showAlert('success', json.success);
                $(buttonElement).closest('.install-module-actions').html('<span class="install-module-installed"><i class="fa fa-check"></i> Установлен</span>');
            } else if (json.error) {
                showAlert('danger', json.error);
                $(buttonElement).prop('disabled', false).html(originalText);
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            showAlert('danger', 'Ошибка установки модуля: ' + thrownError);
            $(buttonElement).prop('disabled', false).html(originalText);
        }
    });
}

// Обработчики событий
$(document).ready(function() {
    // Кнопка настроек
    $('#button-settings').on('click', function() {
        loadSettings();
        $('#modal-settings').modal('show');
    });
    
    // Кнопка установки модулей
    $('#button-install-modules').on('click', function() {
        $('#modal-install-modules').modal('show');
        loadAvailableModules();
    });
    
    // Сохранение настроек
    $('#button-save-settings').on('click', function() {
        saveSettings();
    });
    
    // Проверка обновлений
    $('#button-check').on('click', function() {
        var button = $(this);
        
        $.ajax({
            url: ajaxUrls.checkUpdates,
            dataType: 'json',
            beforeSend: function() {
                button.button('loading');
            },
            complete: function() {
                button.button('reset');
            },
            success: function(json) {
                if (json.error) {
                    showAlert('danger', json.error);
                } else if (json.success) {
                    showAlert('success', json.success);
                    // Перезагружаем страницу
                    setTimeout(function() {
                        location.reload();
                    }, 1000);
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                showAlert('danger', 'Ошибка проверки обновлений: ' + thrownError);
            }
        });
    });
    
    // Обновление модуля
    $(document).on('click', '.update-module', function(e) {
        e.preventDefault();
        
        var element = this;
        var url = $(element).data('url');
        var originalText = $(element).html();
        
        // Отладочный вывод
        console.log('Update URL:', url);
        console.log('Element:', element);
        
        if (!url) {
            showAlert('danger', 'URL для обновления не найден');
            return;
        }
        
        $.ajax({
            url: url,
            dataType: 'json',
            beforeSend: function() {
                $(element).html('<i class="fa fa-spinner fa-spin"></i> Обновление...').addClass('disabled');
            },
            success: function(json) {
                if (json.error) {
                    showAlert('danger', json.error);
                    $(element).html(originalText).removeClass('disabled');
                } else if (json.success) {
                    showAlert('success', json.success);
                    // Перезагружаем страницу после успешного обновления
                    setTimeout(function() {
                        location.reload();
                    }, 2000);
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                showAlert('danger', 'Ошибка обновления: ' + thrownError);
                $(element).html(originalText).removeClass('disabled');
            }
        });
    });
    
    // Восстановление модуля
    // Переключение автообновлений
    $(document).on('click', '.auto-update-link', function(e) {
        e.preventDefault();
        
        var element = this;
        var moduleCode = $(element).data('code');
        var currentState = $(element).data('current');
        var newState = currentState === '1' ? '0' : '1';
        var originalHtml = $(element).html();
        
        $.ajax({
            url: ajaxUrls.toggleAutoUpdate,
            type: 'POST',
            data: {
                module_code: moduleCode,
                auto_update: newState,
                user_token: userToken
            },
            dataType: 'json',
            beforeSend: function() {
                $(element).addClass('disabled').html('<i class="fa fa-spinner fa-spin"></i> Сохранение...');
            },
            success: function(json) {
                $(element).removeClass('disabled');
                if (json.success) {
                    // Обновляем состояние ссылки
                    $(element).data('current', newState);
                    if (newState === '1') {
                        $(element).html('<i class="fa fa-toggle-on"></i> Включены');
                    } else {
                        $(element).html('<i class="fa fa-toggle-off"></i> Отключены');
                    }
                    showAlert('success', 'Настройки автообновления сохранены');
                } else if (json.error) {
                    $(element).html(originalHtml);
                    showAlert('danger', json.error);
                }
            },
            error: function(xhr, ajaxOptions, thrownError) {
                $(element).removeClass('disabled').html(originalHtml);
                showAlert('danger', 'Ошибка сохранения настроек: ' + thrownError);
            }
        });
    });
    
    // Установка модуля
    $(document).on('click', '.install-module-btn', function(e) {
        e.preventDefault();
        var moduleCode = $(this).data('code');
        var downloadUrl = $(this).data('url');
        installModule(moduleCode, downloadUrl, this);
    });
    
    // Поиск модулей
    $(document).on('keyup', '#modules-search', function() {
        var searchTerm = $(this).val().toLowerCase();
        $('.install-module-card').each(function() {
            var moduleTitle = $(this).find('.install-module-title').text().toLowerCase();
            var moduleDescription = $(this).find('.install-module-description').text().toLowerCase();
            
            if (moduleTitle.includes(searchTerm) || moduleDescription.includes(searchTerm)) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    });
    
    // Фильтры модулей
    $(document).on('click', '.filter-btn', function() {
        $('.filter-btn').removeClass('active');
        $(this).addClass('active');
        
        var filter = $(this).data('filter');
        $('.install-module-card').show();
        
        // Здесь можно добавить логику фильтрации по категориям
        // if (filter !== 'all') {
        //     $('.install-module-card').hide();
        //     $('.install-module-card[data-category="' + filter + '"]').show();
        // }
    });
    
    // === ФУНКЦИИ УДАЛЕНИЯ МОДУЛЕЙ ===
    
    // Выбор всех модулей
    $('#select-all-modules').on('change', function() {
        var isChecked = $(this).is(':checked');
        $('.module-checkbox').not('#select-all-modules').prop('checked', isChecked);
        updateDeleteButtonState();
    });
    
    // Выбор отдельного модуля
    $(document).on('change', '.module-checkbox', function() {
        if (!$(this).is('#select-all-modules')) {
            var totalCheckboxes = $('.module-checkbox').not('#select-all-modules').length;
            var checkedCheckboxes = $('.module-checkbox:checked').not('#select-all-modules').length;
            
            $('#select-all-modules').prop('checked', totalCheckboxes === checkedCheckboxes);
            updateDeleteButtonState();
        }
    });
    
    // Обновление состояния кнопки массового удаления
    function updateDeleteButtonState() {
        var checkedCount = $('.module-checkbox:checked').not('#select-all-modules').length;
        $('#button-delete-selected').prop('disabled', checkedCount === 0);
        
        if (checkedCount > 0) {
            $('#button-delete-selected').text(' Удалить выбранные (' + checkedCount + ')');
        } else {
            $('#button-delete-selected').text(' Удалить выбранные');
        }
    }
    
    // Удаление одного модуля
    $(document).on('click', '.delete-module', function(e) {
        e.preventDefault();
        var moduleCode = $(this).data('code');
        var moduleName = $(this).data('name');
        var deleteUrl = $(this).data('url');
        
        showDeleteConfirmation([{code: moduleCode, name: moduleName, url: deleteUrl}], false);
    });
    
    // Массовое удаление модулей
    $('#button-delete-selected').on('click', function() {
        var selectedModules = [];
        $('.module-checkbox:checked').not('#select-all-modules').each(function() {
            var moduleCode = $(this).data('code');
            var moduleItem = $(this).closest('.module-item');
            var moduleName = moduleItem.find('.module-title').text().trim();
            var deleteUrl = moduleItem.find('.delete-module').data('url');
            
            selectedModules.push({
                code: moduleCode,
                name: moduleName,
                url: deleteUrl
            });
        });
        
        if (selectedModules.length > 0) {
            showDeleteConfirmation(selectedModules, true);
        }
    });
    
    // Показ модального окна подтверждения удаления
    function showDeleteConfirmation(modules, isMultiple) {
        var modal = $('#modal-delete-confirm');
        var messageDiv = $('#delete-message');
        var modulesList = $('#modules-to-delete');
        var modulesListUl = $('#delete-modules-list');
        
        if (isMultiple) {
            messageDiv.text('Вы уверены, что хотите удалить выбранные модули? Все файлы модулей будут удалены!');
            modulesList.show();
            modulesListUl.empty();
            
            modules.forEach(function(module) {
                modulesListUl.append('<li>' + module.name + ' (' + module.code + ')</li>');
            });
        } else {
            messageDiv.text('Вы уверены, что хотите удалить модуль "' + modules[0].name + '"? Все файлы модуля будут удалены!');
            modulesList.hide();
        }
        
        // Сохраняем данные модулей для удаления
        modal.data('modules', modules);
        modal.data('isMultiple', isMultiple);
        modal.modal('show');
    }
    
    // Подтверждение удаления
    $('#button-confirm-delete').on('click', function() {
        var modal = $('#modal-delete-confirm');
        var modules = modal.data('modules');
        var isMultiple = modal.data('isMultiple');
        
        modal.modal('hide');
        
        if (isMultiple) {
            deleteMultipleModules(modules);
        } else {
            deleteSingleModule(modules[0]);
        }
    });
    
    // Удаление одного модуля
    function deleteSingleModule(module) {
        $.ajax({
            url: module.url,
            type: 'GET',
            dataType: 'json',
            beforeSend: function() {
                showAlert('info', 'Удаление модуля "' + module.name + '"...');
            },
            success: function(response) {
                if (response.success) {
                    showAlert('success', response.success);
                    // Удаляем строку модуля из списка
                    $('.module-item[data-code="' + module.code + '"]').fadeOut(function() {
                        $(this).remove();
                        updateModulesCount();
                    });
                } else if (response.error) {
                    showAlert('danger', response.error);
                } else if (response.warning) {
                    showAlert('warning', response.warning);
                }
            },
            error: function(xhr, status, error) {
                showAlert('danger', 'Ошибка при удалении модуля: ' + error);
            }
        });
    }
    
    // Массовое удаление модулей
    function deleteMultipleModules(modules) {
        var moduleCodes = modules.map(function(module) {
            return module.code;
        });
        
        $.ajax({
            url: ajaxUrls.deleteMultiple,
            type: 'POST',
            data: {
                modules: moduleCodes
            },
            dataType: 'json',
            beforeSend: function() {
                showAlert('info', 'Удаление ' + modules.length + ' модулей...');
            },
            success: function(response) {
                if (response.success) {
                    showAlert('success', response.success);
                    // Удаляем все выбранные модули из списка
                    moduleCodes.forEach(function(code) {
                        $('.module-item[data-code="' + code + '"]').fadeOut(function() {
                            $(this).remove();
                        });
                    });
                } else if (response.warning) {
                    showAlert('warning', response.warning);
                    // Частично удаляем модули (те, что удалились успешно)
                    // Здесь нужно более сложная логика для определения успешно удаленных
                } else if (response.error) {
                    showAlert('danger', response.error);
                }
                
                // Сбрасываем выбор
                setTimeout(function() {
                    $('.module-checkbox').prop('checked', false);
                    updateDeleteButtonState();
                    updateModulesCount();
                }, 1000);
            },
            error: function(xhr, status, error) {
                showAlert('danger', 'Ошибка при массовом удалении модулей: ' + error);
            }
        });
    }
    
    // Обновление счетчика модулей
    function updateModulesCount() {
        var count = $('.module-item').length;
        $('.modules-list-header').find('i').next().text('Управление модулями (' + count + ')');
        
        if (count === 0) {
            $('.modules-list').html('<div class="no-modules"><i class="fa fa-puzzle-piece"></i><h3>Модули не найдены</h3><p>Установленные модули отсутствуют или не могут быть загружены</p></div>');
        }
    }
    // Локальный поиск по модулям (фильтрация таблички)
    $('#pw-filter-modules').on('input', function() {
        var val = $(this).val().toLowerCase();
        $('#modules-tbody tr').each(function() {
            var text = $(this).text().toLowerCase();
            if(text.indexOf(val) > -1) {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    });
});
//--></script>
