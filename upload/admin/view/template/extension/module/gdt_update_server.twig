{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="index.php?route=extension/module/gdt_update_server/modules&user_token={{ user_token }}" class="btn btn-info"><i class="fa fa-puzzle-piece"></i> {{ text_manage_modules }}</a>
        <button type="submit" form="form-module" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-module" class="form-horizontal">
          
          <!-- Статус модуля -->
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="module_gdt_update_server_status" id="input-status" class="form-control">
                {% if module_gdt_update_server_status %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                <option value="0">{{ text_disabled }}</option>
                {% else %}
                <option value="1">{{ text_enabled }}</option>
                <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>
          
          <!-- API ключ -->
          <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-api-key">{{ entry_api_key }}</label>
            <div class="col-sm-10">
              <input type="text" name="module_gdt_update_server_api_key" value="{{ module_gdt_update_server_api_key }}" placeholder="{{ entry_api_key }}" id="input-api-key" class="form-control" />
              {% if error_api_key %}
              <div class="text-danger">{{ error_api_key }}</div>
              {% endif %}
              <div class="help-block">{{ help_api_key }}</div>
            </div>
          </div>
          
          <!-- Разрешенные IP -->
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-allowed-ips">{{ entry_allowed_ips }}</label>
            <div class="col-sm-10">
              <textarea name="module_gdt_update_server_allowed_ips" rows="5" placeholder="{{ entry_allowed_ips }}" id="input-allowed-ips" class="form-control">{{ module_gdt_update_server_allowed_ips }}</textarea>
              <div class="help-block">{{ help_allowed_ips }}</div>
            </div>
          </div>
          
          <!-- Логирование -->
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-log-enabled">{{ entry_log_enabled }}</label>
            <div class="col-sm-10">
              <select name="module_gdt_update_server_log_enabled" id="input-log-enabled" class="form-control">
                {% if module_gdt_update_server_log_enabled %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                <option value="0">{{ text_disabled }}</option>
                {% else %}
                <option value="1">{{ text_enabled }}</option>
                <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
              <div class="help-block">{{ help_log_enabled }}</div>
            </div>
          </div>
          
        </form>
      </div>
    </div>
    
    <!-- Информация об API -->
    <div class="panel panel-info">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-info-circle"></i> {{ text_api_info }}</h3>
      </div>
      <div class="panel-body">
        <div class="row">
          <div class="col-sm-12">
            <h4>{{ text_api_endpoints }}</h4>
            <table class="table table-bordered">
              <thead>
                <tr>
                  <td>{{ text_endpoint }}</td>
                  <td>{{ text_method }}</td>
                  <td>{{ text_description }}</td>
                  <td>{{ text_url }}</td>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Check</td>
                  <td>POST</td>
                  <td>{{ text_check_description }}</td>
                  <td><code>{{ api_check_url }}</code></td>
                </tr>
                <tr>
                  <td>Download</td>
                  <td>POST</td>
                  <td>{{ text_download_description }}</td>
                  <td><code>{{ api_download_url }}</code></td>
                </tr>
                <tr>
                  <td>Modules</td>
                  <td>GET</td>
                  <td>{{ text_modules_description }}</td>
                  <td><code>{{ api_modules_url }}</code></td>
                </tr>
              </tbody>
            </table>
            
            <h4>{{ text_api_parameters }}</h4>
            <p>{{ text_api_parameters_info }}</p>
            <ul>
              <li><strong>code</strong> - {{ text_param_code }}</li>
              <li><strong>version</strong> - {{ text_param_version }}</li>
              <li><strong>client_id</strong> - {{ text_param_client_id }}</li>
              <li><strong>api_key</strong> - {{ text_param_api_key }}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
    
  </div>
</div>
{{ footer }}
