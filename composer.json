{
    "name": "gbitstudio/ocm-gdt-update",
    "description": "OpenCart Module - GDT Update System",
    "type": "opencart-module",
    "license": "MIT",
    "authors": [
        {
            "name": "GbitStudio",
            "email": "info@gbitstudio.com"
        }
    ],
    "require": {
        "php": ">=7.1.0"
    },
    "require-dev": {
        "gbitstudio/opencart-test-utils": "@dev",
        "mockery/mockery": "^1.5",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "repositories": [
    ],
    "autoload": {
        "classmap": [
            "upload/system/library/gbitstudio/modules/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "phpstan": "phpstan analyse upload/system/library/gbitstudio/modules -l 5",
        "phpcs": "phpcs --standard=PSR12 upload/system/library/gbitstudio/modules"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
